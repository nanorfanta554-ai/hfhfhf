// Helper function to get track by index
function getTrack(index) {
  return MOCK_DATA.tracks[index] || MOCK_DATA.tracks[0];
}

// Get current playing track
function getCurrentTrack() {
  return getTrack(MOCK_DATA.nowPlaying.trackIndex);
}

// Get greeting based on time of day
function getGreeting() {
  const hour = new Date().getHours();
  if (hour >= 5 && hour < 12) return 'Доброе утро';
  if (hour >= 12 && hour < 17) return 'Добрый день';
  if (hour >= 17 && hour < 22) return 'Добрый вечер';
  return 'Доброй ночи';
}

// Get time of day label
function getTimeOfDay() {
  const hour = new Date().getHours();
  if (hour >= 5 && hour < 12) return { label: 'Утреннее', title: 'Энергичное утро', desc: 'Бодрящие треки для хорошего начала дня', gradient: 'linear-gradient(135deg, #1A1A1A 0%, #454545 100%)' };
  if (hour >= 12 && hour < 17) return { label: 'Дневное', title: 'Дневной ритм', desc: 'Фоновая музыка для продуктивности', gradient: 'linear-gradient(135deg, #2B2B2B 0%, #5A5A5A 100%)' };
  if (hour >= 17 && hour < 22) return { label: 'Вечернее', title: 'Вечерний Chill', desc: 'Расслабляющие мелодии для вечера', gradient: 'linear-gradient(135deg, #0F0F0F 0%, #3C3C3C 100%)' };
  return { label: 'Ночное', title: 'Ночной драйв', desc: 'Глубокие треки для ночных часов', gradient: 'linear-gradient(135deg, #050505 0%, #2A2A2A 100%)' };
}

// Format date
function getFormattedDate() {
  const days = ['Воскресенье', 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота'];
  const months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
  const now = new Date();
  return `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]}`;
}


// ============================================
// Never — Audius integration
// ----------------------------------------------------------
// Audius (https://docs.audius.co) is a real, free, no-API-key-needed
// music catalog. Docs recommend sending an app_name identifying your
// app — no registration required for read access like search/trending
// and streaming. This is genuinely real audio, not a mock.
// ============================================

const AUDIUS_APP_NAME = 'Never';
const AUDIUS_HOST = 'https://api.audius.co/v1';

function audiusFormatDuration(totalSeconds) {
  const mins = Math.floor(totalSeconds / 60);
  const secs = Math.floor(totalSeconds % 60).toString().padStart(2, '0');
  return `${mins}:${secs}`;
}

function audiusMapTrack(t) {
  return {
    id: `audius-${t.id}`,
    title: t.title,
    artist: (t.user && (t.user.name || t.user.handle)) || 'Неизвестный исполнитель',
    album: t.album || 'Audius',
    duration: audiusFormatDuration(t.duration || 0),
    artwork: (t.artwork && (t.artwork['480x480'] || t.artwork['150x150'] || t.artwork['1000x1000'])) || null,
    cover: 'cover-3', // fallback gradient if artwork fails to load
    liked: false,
    source: 'audius',
    streamUrl: `${AUDIUS_HOST}/tracks/${t.id}/stream?app_name=${AUDIUS_APP_NAME}`
  };
}

async function audiusFetchTrending(limit = 12) {
  const res = await fetch(`${AUDIUS_HOST}/tracks/trending?app_name=${AUDIUS_APP_NAME}&limit=${limit}`);
  if (!res.ok) throw new Error(`Audius trending failed: ${res.status}`);
  const json = await res.json();
  return (json.data || []).map(audiusMapTrack);
}

async function audiusSearch(query, limit = 20) {
  const res = await fetch(`${AUDIUS_HOST}/tracks/search?query=${encodeURIComponent(query)}&app_name=${AUDIUS_APP_NAME}`);
  if (!res.ok) throw new Error(`Audius search failed: ${res.status}`);
  const json = await res.json();
  return (json.data || []).slice(0, limit).map(audiusMapTrack);
}

// Renders either a real cover image (Audius artwork) or the existing
// CSS gradient placeholder — used everywhere a cover is shown so both
// real and catalog tracks render consistently.
function coverHtml(item, extraClass = '') {
  if (item.artwork) {
    return `<img src="${item.artwork}" alt="" class="cover-img ${extraClass}" loading="lazy" onerror="this.outerHTML='<div class=\\'cover-gradient ${item.cover || 'cover-3'} ${extraClass}\\'></div>'">`;
  }
  return `<div class="cover-gradient ${item.cover || 'cover-3'} ${extraClass}"></div>`;
}


// ============================================
// Never — Auth
// ----------------------------------------------------------
// HOW TO MAKE THIS 100% REAL (5 minutes, free, no server):
//   1. Go to https://console.firebase.google.com → Add project
//   2. Project settings → General → "Your apps" → Add a Web app
//   3. Copy the firebaseConfig object it gives you and paste it
//      below, replacing FIREBASE_CONFIG.
//   4. Authentication → Sign-in method → enable "Email/Password"
//      and "Google". (Apple sign-in also works here but requires
//      an Apple Developer account — $99/yr — to configure.)
//   5. Add your github.io domain under Authentication → Settings
//      → Authorized domains.
// That's it — once apiKey below isn't the placeholder anymore,
// this file automatically switches from demo mode to real
// Firebase accounts (real database, real Google popup, works
// across devices/browsers).
//
// Discord and Telegram CANNOT be wired this way — both require a
// server to verify the login (Discord's OAuth token exchange
// needs a client secret that must never be in frontend code;
// Telegram's Login Widget needs a server holding the bot token
// to verify the payload signature). GitHub Pages can't run that
// server code. They stay as clearly-labeled demo logins below
// until you add a small backend (e.g. a couple of serverless
// functions) — happy to help wire that up if/when you have one.
// ============================================

const FIREBASE_CONFIG = {
  apiKey: "YOUR_API_KEY",
  authDomain: "YOUR_PROJECT.firebaseapp.com",
  projectId: "YOUR_PROJECT",
  storageBucket: "YOUR_PROJECT.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId: "YOUR_APP_ID"
};

class VibeAuth {
  constructor() {
    this.mode = 'login'; // 'login' | 'register'
    this.onReady = null;
    this.usersKey = 'vibe_users';
    this.sessionKey = 'vibe_session';

    this.firebaseReady = FIREBASE_CONFIG.apiKey !== 'YOUR_API_KEY'
      && typeof firebase !== 'undefined';

    if (this.firebaseReady) {
      firebase.initializeApp(FIREBASE_CONFIG);
      this.fbAuth = firebase.auth();
    } else {
      this.seedDemoAccount();
    }
  }

  // Pre-registers a ready-to-use test account so the app is usable
  // immediately, with zero setup, the moment someone opens it.
  seedDemoAccount() {
    const demoEmail = 'didej@11.ee';
    const demoPassword = '111111';
    const users = this.getUsers();
    if (users.some(u => u.email === demoEmail)) return;
    users.push({
      name: 'Тест',
      email: demoEmail,
      passwordHash: this.hash(demoPassword),
      provider: 'email',
      avatar: 'artist-1'
    });
    this.saveUsers(users);
  }

  init(onReady) {
    this.onReady = onReady;
    this.showDemoBanner();

    if (this.firebaseReady) {
      // Real Firebase session check — persists across devices/browsers
      this.fbAuth.onAuthStateChanged((fbUser) => {
        if (fbUser) {
          const user = {
            name: fbUser.displayName || fbUser.email.split('@')[0],
            email: fbUser.email,
            provider: 'firebase',
            avatar: 'artist-1'
          };
          this.applySessionToApp(user);
          this.hideAuthScreen(true);
          if (this.onReady) { this.onReady(); this.onReady = null; }
          else if (typeof app !== 'undefined') { app.populateHome(); app.populateProfile(); }
        } else {
          this.showAuthScreen();
        }
      });
      return;
    }

    // Demo fallback — localStorage session
    const session = this.getSession();
    if (session) {
      this.applySessionToApp(session);
      this.hideAuthScreen(true);
      if (this.onReady) this.onReady();
    } else {
      this.showAuthScreen();
    }
  }

  showDemoBanner() {
    if (this.firebaseReady) return;
    const card = document.querySelector('.auth-card');
    if (!card || document.getElementById('auth-demo-banner')) return;
    const banner = document.createElement('p');
    banner.id = 'auth-demo-banner';
    banner.style.cssText = 'font-size:var(--text-xs);color:var(--text-tertiary);text-align:center;margin-bottom:var(--space-4);line-height:1.5';
    banner.innerHTML = '🔧 Демо-режим — аккаунты хранятся в этом браузере.<br>Готовый тестовый вход: <b>didej@11.ee</b> / <b>111111</b>';
    card.insertBefore(banner, card.firstChild.nextSibling);
  }

  // ── Storage helpers (demo mode only) ─────
  getUsers() {
    try { return JSON.parse(localStorage.getItem(this.usersKey)) || []; }
    catch { return []; }
  }

  saveUsers(users) {
    localStorage.setItem(this.usersKey, JSON.stringify(users));
  }

  getSession() {
    try { return JSON.parse(localStorage.getItem(this.sessionKey)); }
    catch { return null; }
  }

  saveSession(user) {
    localStorage.setItem(this.sessionKey, JSON.stringify(user));
  }

  // Not cryptographically secure — demo mode only, see file header.
  hash(str) {
    let h = 5381;
    for (let i = 0; i < str.length; i++) {
      h = ((h << 5) + h) + str.charCodeAt(i);
      h = h & h;
    }
    return h.toString(36);
  }

  // ── UI ────────────────────────────────────
  showAuthScreen() {
    const screen = document.getElementById('auth-screen');
    if (screen) screen.classList.remove('hidden');
  }

  hideAuthScreen(instant = false) {
    const screen = document.getElementById('auth-screen');
    if (!screen) return;
    if (instant) {
      screen.classList.add('hidden');
    } else {
      setTimeout(() => screen.classList.add('hidden'), 300);
    }
  }

  switchTab(tab) {
    this.mode = tab;
    const isRegister = tab === 'register';

    document.getElementById('auth-tab-login').classList.toggle('active', !isRegister);
    document.getElementById('auth-tab-register').classList.toggle('active', isRegister);
    document.getElementById('auth-field-name').style.display = isRegister ? 'flex' : 'none';
    document.getElementById('auth-field-confirm').style.display = isRegister ? 'flex' : 'none';
    document.getElementById('auth-submit').textContent = isRegister ? 'Зарегистрироваться' : 'Войти';
    document.getElementById('auth-tagline').textContent = isRegister ? 'Создай аккаунт за пару секунд' : 'Заходи и слушай своё';

    const hint = document.getElementById('auth-switch-hint');
    hint.innerHTML = isRegister
      ? 'Уже есть аккаунт? <a onclick="auth.switchTab(\'login\')">Войти</a>'
      : 'Нет аккаунта? <a onclick="auth.switchTab(\'register\')">Зарегистрироваться</a>';

    this.clearError();
  }

  showError(msg) {
    const el = document.getElementById('auth-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.add('visible');
  }

  clearError() {
    const el = document.getElementById('auth-error');
    if (!el) return;
    el.textContent = '';
    el.classList.remove('visible');
  }

  handleSubmit(event) {
    event.preventDefault();
    this.clearError();

    const email = document.getElementById('auth-email').value.trim().toLowerCase();
    const password = document.getElementById('auth-password').value;

    if (!/^\S+@\S+\.\S+$/.test(email)) {
      this.showError('Введите корректный email');
      return false;
    }
    if (password.length < 6) {
      this.showError('Пароль должен быть от 6 символов');
      return false;
    }

    if (this.mode === 'register') {
      const name = document.getElementById('auth-name').value.trim();
      const confirm = document.getElementById('auth-password-confirm').value;
      if (!name) { this.showError('Введите имя'); return false; }
      if (password !== confirm) { this.showError('Пароли не совпадают'); return false; }
      this.register(name, email, password);
    } else {
      this.login(email, password);
    }
    return false;
  }

  register(name, email, password) {
    if (this.firebaseReady) {
      this.fbAuth.createUserWithEmailAndPassword(email, password)
        .then(cred => cred.user.updateProfile({ displayName: name }))
        .then(() => showToast(`👋 Добро пожаловать, ${name}!`))
        .catch(err => this.showError(this.friendlyFirebaseError(err)));
      return;
    }

    // Demo fallback
    const users = this.getUsers();
    if (users.some(u => u.email === email)) {
      this.showError('Этот email уже зарегистрирован — попробуйте войти');
      return;
    }
    const user = { name, email, passwordHash: this.hash(password), provider: 'email', avatar: 'artist-1' };
    users.push(user);
    this.saveUsers(users);
    this.completeLogin(user);
    showToast(`👋 Добро пожаловать, ${name}!`);
  }

  login(email, password) {
    if (this.firebaseReady) {
      this.fbAuth.signInWithEmailAndPassword(email, password)
        .catch(err => this.showError(this.friendlyFirebaseError(err)));
      return;
    }

    // Demo fallback
    const users = this.getUsers();
    const user = users.find(u => u.email === email);
    if (!user || user.passwordHash !== this.hash(password)) {
      this.showError('Неверный email или пароль');
      return;
    }
    this.completeLogin(user);
    showToast(`👋 С возвращением, ${user.name}!`);
  }

  friendlyFirebaseError(err) {
    const map = {
      'auth/email-already-in-use': 'Этот email уже зарегистрирован — попробуйте войти',
      'auth/invalid-email': 'Некорректный email',
      'auth/weak-password': 'Пароль слишком простой',
      'auth/user-not-found': 'Пользователь не найден',
      'auth/wrong-password': 'Неверный пароль',
      'auth/popup-closed-by-user': 'Окно входа было закрыто'
    };
    return map[err.code] || err.message;
  }

  loginWithProvider(provider) {
    if (this.firebaseReady && (provider === 'google' || provider === 'apple')) {
      const fbProvider = provider === 'google'
        ? new firebase.auth.GoogleAuthProvider()
        : new firebase.auth.OAuthProvider('apple.com');
      this.fbAuth.signInWithPopup(fbProvider)
        .then(cred => showToast(`✅ Вход через ${provider === 'google' ? 'Google' : 'Apple'} выполнен`))
        .catch(err => this.showError(this.friendlyFirebaseError(err)));
      return;
    }

    // Discord / Telegram (and Google/Apple before Firebase is configured)
    // genuinely can't do a real OAuth round-trip from a static site alone —
    // see the file header. This creates a clearly-labeled demo profile.
    const demoProfiles = {
      google: { name: 'Алексей', email: 'alexey@gmail.com' },
      apple: { name: 'Алексей', email: 'alexey@icloud.com' },
      discord: { name: 'Алексей', email: 'alexey#0420' },
      telegram: { name: 'Алексей', email: '@alexey_vibe' }
    };
    const profile = demoProfiles[provider] || { name: 'Алексей', email: 'alexey@vibe.app' };
    const user = { name: profile.name, email: profile.email, provider, avatar: 'artist-1' };
    this.completeLogin(user);
    const providerName = provider[0].toUpperCase() + provider.slice(1);
    const isRealCapable = provider === 'google' || provider === 'apple';
    showToast(isRealCapable
      ? `✅ Демо-вход через ${providerName} (настройте Firebase для настоящего входа)`
      : `✅ Демо-вход через ${providerName} (нужен бэкенд для настоящего входа)`);
  }

  completeLogin(user) {
    this.saveSession(user);
    this.applySessionToApp(user);
    this.hideAuthScreen();

    if (this.onReady) {
      this.onReady();
      this.onReady = null;
    } else if (typeof app !== 'undefined') {
      app.populateHome();
      app.populateProfile();
    }
  }

  applySessionToApp(user) {
    MOCK_DATA.user.name = user.name;
    MOCK_DATA.user.handle = user.provider === 'email' || user.provider === 'firebase'
      ? `@${user.email.split('@')[0]}`
      : user.email;
    const emailLabel = document.getElementById('logout-account-email');
    if (emailLabel) emailLabel.textContent = user.email;
  }

  logout() {
    if (!confirm('Выйти из аккаунта?')) return;
    if (this.firebaseReady) {
      this.fbAuth.signOut().then(() => location.reload());
      return;
    }
    localStorage.removeItem(this.sessionKey);
    location.reload();
  }
}

const auth = new VibeAuth();



// ============================================
// Never — SPA Router
// ============================================

class VibeRouter {
  constructor() {
    this.currentTab = 'home';
    this.screens = {};
    this.navItems = {};
    this.onTabChange = null;
    this.history = ['home'];
  }

  init() {
    // Cache DOM elements
    document.querySelectorAll('.screen').forEach(screen => {
      const id = screen.id.replace('screen-', '');
      this.screens[id] = screen;
    });

    document.querySelectorAll('.nav-item').forEach(item => {
      const tab = item.dataset.tab;
      this.navItems[tab] = item;

      item.addEventListener('click', (e) => {
        e.preventDefault();
        this.navigate(tab);
      });
    });

    // Set initial active
    this.setActive('home', false);
  }

  navigate(tab) {
    if (tab === this.currentTab) {
      // Scroll to top if same tab
      const screen = this.screens[tab];
      if (screen) {
        screen.scrollTo({ top: 0, behavior: 'smooth' });
      }
      return;
    }

    this.setActive(tab, true);
  }

  setActive(tab, animate = true) {
    const prevTab = this.currentTab;

    // Deactivate current screen and nav
    Object.values(this.screens).forEach(s => s.classList.remove('active'));
    Object.values(this.navItems).forEach(n => n.classList.remove('active'));

    // Activate new screen and nav
    if (this.screens[tab]) {
      this.screens[tab].classList.add('active');

      if (animate) {
        // Add stagger animation to cards
        const cards = this.screens[tab].querySelectorAll('.card-stagger');
        cards.forEach((card, i) => {
          card.style.animation = 'none';
          card.offsetHeight; // Force reflow
          card.style.animation = '';
        });
      }
    }

    if (this.navItems[tab]) {
      this.navItems[tab].classList.add('active');

      if (animate) {
        // Tab switch animation
        const icon = this.navItems[tab].querySelector('svg');
        if (icon) {
          icon.style.animation = 'none';
          icon.offsetHeight;
          icon.style.animation = 'tabPulse 0.4s var(--ease-spring) forwards';
        }
      }
    }

    this.currentTab = tab;

    // Track history
    if (this.history[this.history.length - 1] !== tab) {
      this.history.push(tab);
      if (this.history.length > 20) this.history.shift();
    }

    // Callback
    if (this.onTabChange) {
      this.onTabChange(tab, prevTab);
    }
  }

  goBack() {
    if (this.history.length > 1) {
      this.history.pop();
      const prevTab = this.history[this.history.length - 1];
      this.setActive(prevTab, true);
      return true;
    }
    return false;
  }
}

// Create global router instance
const router = new VibeRouter();


// ============================================
// Never — Audio Player Controller
// ============================================

class VibePlayer {
  constructor() {
    this.isPlaying = false;
    this.currentTrackIndex = 0;
    this.progress = 35;
    this.shuffle = false;
    this.repeat = 'off';
    this.liked = true;
    this.isPlayerOpen = false;
    this.vinylMode = false;
    this.lyricsOpen = false;
    this.visualizerBars = [];
    this.visualizerRAF = null;
    this.progressInterval = null;

    // Real audio engine — native HTML5 <audio>, see initAudioEngine()
    this.audioEl = null;

    // DOM Elements (will be set in init)
    this.els = {};
  }

  init() {
    // Cache DOM elements
    this.els = {
      miniPlayer: document.getElementById('mini-player'),
      fullPlayer: document.getElementById('player-fullscreen'),
      bottomNav: document.querySelector('.bottom-nav'),
      // Mini player elements
      miniCover: document.querySelector('.mini-player-cover .cover-gradient'),
      miniTitle: document.querySelector('.mini-player-title'),
      miniArtist: document.querySelector('.mini-player-artist'),
      miniPlayBtn: document.getElementById('mini-play-btn'),
      // Full player elements
      playerBg: document.querySelector('.player-bg-image'),
      playerCover: document.querySelector('.player-cover'),
      playerCoverImg: document.querySelector('.player-cover .cover-gradient'),
      playerTitle: document.querySelector('.player-track-title'),
      playerArtist: document.querySelector('.player-track-artist'),
      playerProgressFill: document.querySelector('.player-progress-fill'),
      playerProgressBar: document.querySelector('.player-progress-bar'),
      playerCurrentTime: document.getElementById('player-current-time'),
      playerDuration: document.getElementById('player-duration'),
      playerPlayBtn: document.getElementById('player-play-btn'),
      playerShuffleBtn: document.getElementById('player-shuffle-btn'),
      playerRepeatBtn: document.getElementById('player-repeat-btn'),
      playerLikeBtn: document.getElementById('player-like-btn'),
      playerPrevBtn: document.getElementById('player-prev-btn'),
      playerNextBtn: document.getElementById('player-next-btn'),
      playerCloseBtn: document.getElementById('player-close-btn'),
      playerVinylBtn: document.getElementById('player-vinyl-btn'),
      playerLyricsBtn: document.getElementById('player-lyrics-btn'),
      playerQueueBtn: document.getElementById('player-queue-btn'),
      playerEqBtn: document.getElementById('player-eq-btn'),
      lyricsOverlay: document.getElementById('lyrics-overlay'),
      lyricsCloseBtn: document.getElementById('lyrics-close-btn'),
      visualizer: document.querySelector('.player-visualizer')
    };

    this.setupEventListeners();
    this.updateUI();
    this.initVisualizer();
    this.initAudioEngine();
  }

  // Real audio playback via a plain HTML5 <audio> element streaming
  // directly from Audius (see js/audius.js) — genuine audio, not a
  // simulation. Only tracks with track.source === 'audius' (real,
  // fetched from Audius at startup) are wired up to actual sound.
  initAudioEngine() {
    this.audioEl = document.getElementById('audio-engine');
    if (!this.audioEl) return;

    this.audioEl.addEventListener('play', () => {
      this.isPlaying = true;
      this.updatePlayButton();
      this.updateVisualizer();
      if (this.vinylMode && this.els.playerCover) {
        this.els.playerCover.classList.remove('vinyl-paused');
      }
    });

    this.audioEl.addEventListener('pause', () => {
      this.isPlaying = false;
      this.updatePlayButton();
      this.updateVisualizer();
      if (this.vinylMode && this.els.playerCover) {
        this.els.playerCover.classList.add('vinyl-paused');
      }
    });

    this.audioEl.addEventListener('timeupdate', () => {
      if (!this.audioEl.duration) return;
      this.progress = (this.audioEl.currentTime / this.audioEl.duration) * 100;
      this.updateProgress(this.audioEl.currentTime * 1000, this.audioEl.duration * 1000);
    });

    this.audioEl.addEventListener('ended', () => {
      if (this.repeat === 'one') {
        this.audioEl.currentTime = 0;
        this.audioEl.play();
      } else {
        this.nextTrack();
      }
    });

    this.audioEl.addEventListener('error', () => {
      showToast('⚠️ Не удалось загрузить трек — проверьте интернет-соединение');
    });
  }

  setupEventListeners() {
    // Mini player → open full player
    if (this.els.miniPlayer) {
      this.els.miniPlayer.addEventListener('click', (e) => {
        if (e.target.closest('.mini-player-btn')) return;
        this.openPlayer();
      });
    }

    // Mini play/pause
    if (this.els.miniPlayBtn) {
      this.els.miniPlayBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        this.togglePlay();
      });
    }

    // Close full player
    if (this.els.playerCloseBtn) {
      this.els.playerCloseBtn.addEventListener('click', () => this.closePlayer());
    }

    // Full player play/pause
    if (this.els.playerPlayBtn) {
      this.els.playerPlayBtn.addEventListener('click', () => this.togglePlay());
    }

    // Next / Prev
    if (this.els.playerNextBtn) {
      this.els.playerNextBtn.addEventListener('click', () => this.nextTrack());
    }
    if (this.els.playerPrevBtn) {
      this.els.playerPrevBtn.addEventListener('click', () => this.prevTrack());
    }

    // Shuffle
    if (this.els.playerShuffleBtn) {
      this.els.playerShuffleBtn.addEventListener('click', () => this.toggleShuffle());
    }

    // Repeat
    if (this.els.playerRepeatBtn) {
      this.els.playerRepeatBtn.addEventListener('click', () => this.toggleRepeat());
    }

    // Like
    if (this.els.playerLikeBtn) {
      this.els.playerLikeBtn.addEventListener('click', () => this.toggleLike());
    }

    // Vinyl mode
    if (this.els.playerVinylBtn) {
      this.els.playerVinylBtn.addEventListener('click', () => this.toggleVinyl());
    }

    // Lyrics
    if (this.els.playerLyricsBtn) {
      this.els.playerLyricsBtn.addEventListener('click', () => this.toggleLyrics());
    }
    if (this.els.lyricsCloseBtn) {
      this.els.lyricsCloseBtn.addEventListener('click', () => this.toggleLyrics());
    }

    // Equalizer (was dead — opens the same EQ modal as in Settings)
    if (this.els.playerEqBtn) {
      this.els.playerEqBtn.addEventListener('click', () => ui.renderEqModal());
    }

    // Queue (was dead — shows what's up next)
    if (this.els.playerQueueBtn) {
      this.els.playerQueueBtn.addEventListener('click', () => ui.renderQueueModal());
    }

    // "..." more menu (was dead)
    const moreBtn = document.getElementById('player-more-btn');
    if (moreBtn) {
      moreBtn.addEventListener('click', () => ui.renderTrackMoreModal());
    }

    // Progress bar seek
    if (this.els.playerProgressBar) {
      this.els.playerProgressBar.addEventListener('click', (e) => {
        const rect = this.els.playerProgressBar.getBoundingClientRect();
        const percent = ((e.clientX - rect.left) / rect.width) * 100;
        this.seekTo(Math.max(0, Math.min(100, percent)));
      });
    }

    // Swipe down to close
    if (this.els.fullPlayer) {
      let startY = 0;
      let currentY = 0;

      this.els.fullPlayer.addEventListener('touchstart', (e) => {
        startY = e.touches[0].clientY;
      }, { passive: true });

      this.els.fullPlayer.addEventListener('touchmove', (e) => {
        currentY = e.touches[0].clientY;
        const diff = currentY - startY;
        if (diff > 0 && diff < 300) {
          this.els.fullPlayer.style.transform = `translateX(-50%) translateY(${diff}px)`;
          this.els.fullPlayer.style.opacity = 1 - (diff / 400);
        }
      }, { passive: true });

      this.els.fullPlayer.addEventListener('touchend', () => {
        const diff = currentY - startY;
        if (diff > 120) {
          this.closePlayer();
        } else {
          this.els.fullPlayer.style.transform = '';
          this.els.fullPlayer.style.opacity = '';
        }
      });
    }
  }

  openPlayer() {
    if (this.els.fullPlayer) {
      this.els.fullPlayer.classList.add('open');
      this.els.fullPlayer.style.transform = '';
      this.els.fullPlayer.style.opacity = '';
      this.isPlayerOpen = true;

      // Hide nav and mini player
      if (this.els.bottomNav) this.els.bottomNav.classList.add('hidden');

      document.body.style.overflow = 'hidden';
    }
  }

  closePlayer() {
    if (this.els.fullPlayer) {
      this.els.fullPlayer.classList.remove('open');
      this.els.fullPlayer.style.transform = '';
      this.els.fullPlayer.style.opacity = '';
      this.isPlayerOpen = false;

      // Show nav
      if (this.els.bottomNav) this.els.bottomNav.classList.remove('hidden');

      document.body.style.overflow = '';

      // Close lyrics if open
      if (this.lyricsOpen) this.toggleLyrics();
    }
  }

  togglePlay() {
    const track = getTrack(this.currentTrackIndex);

    if (track.source === 'audius' && this.audioEl && this.audioEl.src) {
      if (this.audioEl.paused) this.audioEl.play();
      else this.audioEl.pause();
      // isPlaying/vinyl/visualizer get updated by the play/pause
      // audio events themselves (see initAudioEngine).
    } else {
      showToast('🎧 Реальное аудио пока подключено только для треков из Audius — остальной каталог в разработке');
      return;
    }

    // Animate play button
    const btn = this.isPlayerOpen ? this.els.playerPlayBtn : this.els.miniPlayBtn;
    if (btn) {
      btn.classList.add('scale-bounce');
      setTimeout(() => btn.classList.remove('scale-bounce'), 350);
    }
  }

  // Indexes of tracks that are actually wired to real audio
  getPlayableIndexes() {
    return MOCK_DATA.tracks
      .map((t, i) => (t.source === 'audius' ? i : null))
      .filter(i => i !== null);
  }

  nextTrack() {
    const playable = this.getPlayableIndexes();
    if (!playable.length) return;
    const pos = playable.indexOf(this.currentTrackIndex);

    if (this.shuffle) {
      this.currentTrackIndex = playable[Math.floor(Math.random() * playable.length)];
    } else {
      const nextPos = pos === -1 ? 0 : (pos + 1) % playable.length;
      this.currentTrackIndex = playable[nextPos];
    }
    this.progress = 0;
    this.playTrack(this.currentTrackIndex);

    // Animate cover
    if (this.els.playerCover) {
      this.els.playerCover.style.animation = 'none';
      this.els.playerCover.offsetHeight;
      this.els.playerCover.style.animation = 'fadeInScale 0.5s var(--ease-spring-soft) forwards';
    }
  }

  prevTrack() {
    if (this.progress > 10) {
      this.seekTo(0);
      return;
    }

    const playable = this.getPlayableIndexes();
    if (!playable.length) return;
    const pos = playable.indexOf(this.currentTrackIndex);

    if (this.shuffle) {
      this.currentTrackIndex = playable[Math.floor(Math.random() * playable.length)];
    } else {
      const prevPos = pos === -1 ? 0 : (pos - 1 + playable.length) % playable.length;
      this.currentTrackIndex = playable[prevPos];
    }
    this.progress = 0;
    this.playTrack(this.currentTrackIndex);
  }

  loadTrack() {
    const track = getTrack(this.currentTrackIndex);
    this.liked = track.liked;
    this.updateUI();
    showToast(`🎵 ${track.title} — ${track.artist}`);
  }

  toggleShuffle() {
    this.shuffle = !this.shuffle;
    if (this.els.playerShuffleBtn) {
      this.els.playerShuffleBtn.classList.toggle('active', this.shuffle);
    }
    showToast(this.shuffle ? '🔀 Перемешивание включено' : '🔀 Перемешивание выключено');
  }

  toggleRepeat() {
    const modes = ['off', 'all', 'one'];
    const currentIndex = modes.indexOf(this.repeat);
    this.repeat = modes[(currentIndex + 1) % modes.length];

    if (this.els.playerRepeatBtn) {
      this.els.playerRepeatBtn.classList.toggle('active', this.repeat !== 'off');

      const svg = this.els.playerRepeatBtn.querySelector('svg');
      if (this.repeat === 'one' && svg) {
        svg.innerHTML = '<path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 014-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/><text x="12" y="15" text-anchor="middle" fill="currentColor" font-size="8" font-weight="bold" stroke="none">1</text>';
      } else if (svg) {
        svg.innerHTML = '<path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 014-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/>';
      }
    }

    const msgs = { off: '🔁 Повтор выключен', all: '🔁 Повтор плейлиста', one: '🔂 Повтор трека' };
    showToast(msgs[this.repeat]);
  }

  toggleLike() {
    this.liked = !this.liked;

    if (this.els.playerLikeBtn) {
      this.els.playerLikeBtn.classList.toggle('liked', this.liked);
      if (this.liked) {
        this.els.playerLikeBtn.classList.add('heart-beat');
        setTimeout(() => this.els.playerLikeBtn.classList.remove('heart-beat'), 600);
      }
    }

    const track = getTrack(this.currentTrackIndex);
    track.liked = this.liked;
    // Sync liked-count in library
    const likedCount = document.getElementById('liked-count');
    if (likedCount) {
      const count = MOCK_DATA.tracks.filter(t => t.liked).length;
      likedCount.textContent = `${count} треков`;
    }
    showToast(this.liked ? '❤️ Добавлено в любимые' : '💔 Удалено из любимых');
  }

  toggleVinyl() {
    this.vinylMode = !this.vinylMode;

    if (this.els.playerCover) {
      this.els.playerCover.classList.toggle('vinyl-mode', this.vinylMode);
      if (this.vinylMode) {
        this.els.playerCover.classList.add('vinyl-spinning');
        if (!this.isPlaying) {
          this.els.playerCover.classList.add('vinyl-paused');
        }
      } else {
        this.els.playerCover.classList.remove('vinyl-spinning', 'vinyl-paused');
      }
    }

    if (this.els.playerVinylBtn) {
      this.els.playerVinylBtn.classList.toggle('active', this.vinylMode);
    }

    showToast(this.vinylMode ? '💿 Режим пластинки' : '🖼 Режим обложки');
  }

  toggleLyrics() {
    this.lyricsOpen = !this.lyricsOpen;
    if (this.els.lyricsOverlay) {
      this.els.lyricsOverlay.classList.toggle('open', this.lyricsOpen);
    }
    if (this.els.playerLyricsBtn) {
      this.els.playerLyricsBtn.classList.toggle('active', this.lyricsOpen);
    }
  }

  seekTo(percent) {
    this.progress = percent;
    const track = getTrack(this.currentTrackIndex);
    if (track.source === 'audius' && this.audioEl && this.audioEl.duration) {
      this.audioEl.currentTime = (percent / 100) * this.audioEl.duration;
    } else {
      this.updateProgress();
    }
  }

  // UI Updates
  // Applies either a real artwork image (Audius) or the CSS gradient
  // placeholder to a .cover-gradient element.
  applyCover(el, track, extraClass = '') {
    if (!el) return;
    if (track.artwork) {
      el.className = `cover-gradient ${extraClass}`;
      el.style.backgroundImage = `url("${track.artwork}")`;
      el.style.backgroundSize = 'cover';
      el.style.backgroundPosition = 'center';
    } else {
      el.className = `cover-gradient ${track.cover} ${extraClass}`;
      el.style.backgroundImage = '';
    }
  }

  updateUI() {
    const track = getTrack(this.currentTrackIndex);

    // Mini player
    this.applyCover(this.els.miniCover, track);
    if (this.els.miniTitle) this.els.miniTitle.textContent = track.title;
    if (this.els.miniArtist) this.els.miniArtist.textContent = track.artist;

    // Full player
    this.applyCover(this.els.playerBg, track, 'player-bg-image');
    this.applyCover(this.els.playerCoverImg, track);
    if (this.els.playerTitle) this.els.playerTitle.textContent = track.title;
    if (this.els.playerArtist) this.els.playerArtist.textContent = track.artist;
    if (this.els.playerDuration) this.els.playerDuration.textContent = track.duration;

    // Like button
    if (this.els.playerLikeBtn) {
      this.els.playerLikeBtn.classList.toggle('liked', this.liked);
    }

    this.updatePlayButton();
    this.updateProgress();
  }

  updatePlayButton() {
    const playIcon = '<svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
    const pauseIcon = '<svg viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';

    if (this.els.miniPlayBtn) {
      this.els.miniPlayBtn.innerHTML = this.isPlaying ? pauseIcon : playIcon;
    }
    if (this.els.playerPlayBtn) {
      this.els.playerPlayBtn.innerHTML = this.isPlaying ? pauseIcon : playIcon;
    }

    // Update equalizer visibility (fade only — never removed from
    // the flex flow, so play/pause never shifts the buttons beside it)
    const eqMini = document.getElementById('mini-eq');
    if (eqMini) {
      eqMini.classList.toggle('paused', !this.isPlaying);
    }
  }

  updateProgress(currentMs, durationMs) {
    // Mini player progress
    if (this.els.miniPlayer) {
      this.els.miniPlayer.style.setProperty('--progress', `${this.progress}%`);
    }

    // Full player progress
    if (this.els.playerProgressFill) {
      this.els.playerProgressFill.style.width = `${this.progress}%`;
    }

    // Time display
    if (this.els.playerCurrentTime) {
      let currentSeconds;
      if (typeof currentMs === 'number') {
        currentSeconds = Math.floor(currentMs / 1000);
      } else {
        const track = getTrack(this.currentTrackIndex);
        const durationParts = track.duration.split(':');
        const totalSeconds = parseInt(durationParts[0]) * 60 + parseInt(durationParts[1]);
        currentSeconds = Math.floor((this.progress / 100) * totalSeconds);
      }
      const minutes = Math.floor(currentSeconds / 60);
      const seconds = currentSeconds % 60;
      this.els.playerCurrentTime.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
    }

    // Update active lyric line
    this.updateLyrics();
  }

  updateLyrics() {
    if (!this.lyricsOpen) return;

    const track = getTrack(this.currentTrackIndex);
    const durationParts = track.duration.split(':');
    const totalSeconds = parseInt(durationParts[0]) * 60 + parseInt(durationParts[1]);
    const currentSeconds = Math.floor((this.progress / 100) * totalSeconds);

    const lines = document.querySelectorAll('.lyrics-line');
    let activeIndex = 0;

    MOCK_DATA.lyrics.forEach((lyric, i) => {
      if (currentSeconds >= lyric.time) activeIndex = i;
    });

    lines.forEach((line, i) => {
      line.classList.toggle('active', i === activeIndex);
    });
  }

  // Visualizer
  initVisualizer() {
    if (!this.els.visualizer) return;

    const barCount = 24;
    this.els.visualizer.innerHTML = '';

    for (let i = 0; i < barCount; i++) {
      const bar = document.createElement('div');
      bar.className = 'player-viz-bar';
      bar.style.height = '4px';
      this.els.visualizer.appendChild(bar);
      this.visualizerBars.push(bar);
    }

    this.updateVisualizer();
  }

  updateVisualizer() {
    if (this.visualizerRAF) {
      cancelAnimationFrame(this.visualizerRAF);
    }

    if (!this.isPlaying) {
      // Set bars to minimum
      this.visualizerBars.forEach(bar => {
        bar.style.height = '4px';
        bar.style.opacity = '0.3';
      });
      return;
    }

    const animate = () => {
      this.visualizerBars.forEach((bar, i) => {
        const baseHeight = 4;
        const maxHeight = 36;
        const height = baseHeight + Math.random() * (maxHeight - baseHeight);
        const smoothHeight = baseHeight + (height - baseHeight) * (0.5 + 0.5 * Math.sin(Date.now() / (200 + i * 30) + i));
        bar.style.height = `${smoothHeight}px`;
        bar.style.opacity = '0.6';
      });

      this.visualizerRAF = requestAnimationFrame(animate);
    };

    animate();
  }

  // Play specific track
  playTrack(index) {
    const track = getTrack(index);

    if (track.source !== 'audius' || !track.streamUrl || !this.audioEl) {
      showToast('🎧 Пока по-настоящему играют только треки из Audius (со значком ●) — остальной каталог в разработке');
      return;
    }

    this.currentTrackIndex = index;
    this.progress = 0;
    this.liked = track.liked;
    this.updateUI();
    showToast(`🎵 ${track.title} — ${track.artist}`);

    this.audioEl.src = track.streamUrl;
    this.audioEl.play().catch(() => {
      showToast('⚠️ Не удалось начать воспроизведение');
    });
  }
}

// Create global player instance
const player = new VibePlayer();

// Toast notification
function showToast(message) {
  let toast = document.getElementById('toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'toast';
    toast.className = 'toast';
    document.body.appendChild(toast);
  }

  toast.textContent = message;
  toast.classList.remove('show');
  toast.offsetHeight; // Force reflow
  toast.classList.add('show');

  clearTimeout(toast._timeout);
  toast._timeout = setTimeout(() => {
    toast.classList.remove('show');
  }, 2500);
}


// ============================================
// Never — UI Interactions
// ============================================

class VibeUI {
  constructor() {
    this.scrollPositions = {};
  }

  init() {
    this.setupRippleEffect();
    this.setupTrackClicks();
    this.setupToggleSwitches();
    this.setupLikeButtons();
    this.setupPullToRefresh();
    this.setupParallaxCovers();
    this.setupScrollEffects();
    this.setupDetailModalClose();
    this.setupGlobalDelegatedClicks();
    this.setupSectionActions();
    this.setupLibrarySearch();
    this.setupProfileButtons();
    this.setupConcertCards();
  }

  // Ripple effect on click
  setupRippleEffect() {
    document.querySelectorAll('.ripple-effect').forEach(el => {
      el.addEventListener('click', function(e) {
        const ripple = document.createElement('span');
        ripple.className = 'ripple';
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height) * 2;
        ripple.style.width = ripple.style.height = size + 'px';
        ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
        ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
        this.appendChild(ripple);
        setTimeout(() => ripple.remove(), 600);
      });
    });
  }

  // Track card clicks → play that track
  setupTrackClicks() {
    document.querySelectorAll('.track-card').forEach(card => {
      card.addEventListener('click', () => {
        const index = parseInt(card.dataset.trackIndex);
        if (!isNaN(index)) {
          // Remove playing state from all tracks
          document.querySelectorAll('.track-card.playing').forEach(c => c.classList.remove('playing'));
          card.classList.add('playing');
          player.playTrack(index);
        }
      });
    });
  }

  // Toggle switches (appearance toggles — theme/glass/animations —
  // are handled separately in setupAppearanceToggles, which owns
  // their visual state too, so they're skipped here to avoid two
  // handlers fighting over the same class)
  setupToggleSwitches() {
    const appearanceIds = ['toggle-theme', 'toggle-glass', 'toggle-animations'];
    document.querySelectorAll('.toggle').forEach(toggle => {
      if (appearanceIds.includes(toggle.id)) return;
      toggle.addEventListener('click', function() {
        this.classList.toggle('active');
        // Spring animation
        this.style.transform = 'scale(0.9)';
        setTimeout(() => {
          this.style.transform = 'scale(1)';
        }, 150);
      });
    });
  }

  // Like buttons (outside player)
  setupLikeButtons() {
    document.querySelectorAll('.like-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        this.classList.toggle('liked');
        if (this.classList.contains('liked')) {
          this.classList.add('heart-beat');
          setTimeout(() => this.classList.remove('heart-beat'), 600);
          showToast('❤️ Добавлено в любимые');
        } else {
          showToast('💔 Удалено из любимых');
        }
      });
    });
  }

  // Pull to refresh simulation
  setupPullToRefresh() {
    document.querySelectorAll('.screen').forEach(screen => {
      let startY = 0;
      let pulling = false;

      screen.addEventListener('touchstart', (e) => {
        if (screen.scrollTop === 0) {
          startY = e.touches[0].clientY;
          pulling = true;
        }
      }, { passive: true });

      screen.addEventListener('touchmove', (e) => {
        if (!pulling) return;
        const diff = e.touches[0].clientY - startY;
        if (diff > 0 && diff < 100) {
          screen.style.transform = `translateY(${diff * 0.4}px)`;
        }
      }, { passive: true });

      screen.addEventListener('touchend', () => {
        if (pulling) {
          screen.style.transition = 'transform 0.3s var(--ease-spring)';
          screen.style.transform = '';
          setTimeout(() => {
            screen.style.transition = '';
          }, 300);
          pulling = false;
        }
      });
    });
  }

  // Parallax on album covers
  setupParallaxCovers() {
    const covers = document.querySelectorAll('.album-card');
    covers.forEach(cover => {
      cover.addEventListener('mousemove', (e) => {
        const rect = cover.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        const img = cover.querySelector('.album-card-cover');
        if (img) {
          img.style.transform = `perspective(500px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg)`;
        }
      });

      cover.addEventListener('mouseleave', () => {
        const img = cover.querySelector('.album-card-cover');
        if (img) {
          img.style.transform = '';
          img.style.transition = 'transform 0.5s var(--ease-spring-soft)';
          setTimeout(() => { img.style.transition = ''; }, 500);
        }
      });
    });
  }

  // Scroll effects (header fade, etc.)
  setupScrollEffects() {
    document.querySelectorAll('.screen').forEach(screen => {
      screen.addEventListener('scroll', () => {
        const scrollY = screen.scrollTop;
        // Store scroll position
        this.scrollPositions[screen.id] = scrollY;

        // Fade hero on scroll
        const hero = screen.querySelector('.home-hero, .foryou-header, .library-header');
        if (hero) {
          const opacity = Math.max(0, 1 - scrollY / 200);
          hero.style.opacity = opacity;
          hero.style.transform = `translateY(${-scrollY * 0.3}px)`;
        }
      }, { passive: true });
    });
  }

  // Animate counter numbers
  animateCounter(element, target, duration = 1500) {
    const start = 0;
    const startTime = performance.now();

    const update = (currentTime) => {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);

      // Easing
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(start + (target - start) * eased);

      element.textContent = current.toLocaleString();

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    };

    requestAnimationFrame(update);
  }

  // Show section with stagger animation
  revealSection(sectionEl) {
    const cards = sectionEl.querySelectorAll('.card-stagger');
    cards.forEach((card, i) => {
      card.style.animationDelay = `${i * 60}ms`;
    });
  }

  // ── Generic Detail Modal ─────────────────
  // Used by album cards, library categories and settings rows —
  // all of which previously had no click handler at all.
  openDetailModal(html) {
    const modal = document.getElementById('detail-modal');
    const body = document.getElementById('detail-modal-body');
    if (!modal || !body) return;
    body.innerHTML = html;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  closeDetailModal() {
    const modal = document.getElementById('detail-modal');
    if (!modal) return;
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  setupDetailModalClose() {
    const modal = document.getElementById('detail-modal');
    const closeBtn = document.getElementById('detail-modal-close-btn');
    if (closeBtn) {
      closeBtn.addEventListener('click', () => this.closeDetailModal());
    }
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) this.closeDetailModal();
      });
    }
    document.addEventListener('keydown', (e) => {
      if (e.code === 'Escape') this.closeDetailModal();
    });
  }

  // Single delegated listener catches clicks on album cards, library
  // categories and settings rows — including ones rendered by JS later,
  // so nothing needs to be re-bound after populateHome()/populateForYou().
  setupGlobalDelegatedClicks() {
    document.addEventListener('click', (e) => {
      // Play button inside an album card — play, don't open the modal
      const playFab = e.target.closest('.play-fab');
      if (playFab) return; // has its own onclick with stopPropagation

      // Album / playlist card → open detail modal
      const albumCard = e.target.closest('.album-card');
      if (albumCard) {
        this.openAlbumDetail(albumCard);
        return;
      }

      // Library category (skip "Любимые треки", it already has its own onclick)
      const libCat = e.target.closest('.lib-category');
      if (libCat && !libCat.hasAttribute('onclick')) {
        this.openLibraryCategory(libCat);
        return;
      }

      // Settings row that navigates somewhere (has a chevron) —
      // pure toggle rows are handled separately and shouldn't open a modal
      const settingRow = e.target.closest('.setting-row');
      if (settingRow && settingRow.querySelector('.chevron-right') && !e.target.closest('.toggle')) {
        this.openSettingDetail(settingRow);
        return;
      }
    });
  }

  openAlbumDetail(card) {
    const title = card.querySelector('.album-card-title')?.textContent.trim() || 'Альбом';
    const subtitle = card.querySelector('.album-card-subtitle')?.textContent.trim() || '';
    const coverEl = card.querySelector('.cover-gradient');
    const coverClass = coverEl ? [...coverEl.classList].find(c => c.startsWith('cover-')) : 'cover-1';

    // Show the real tracklist when we can match it by album name
    const matchingTracks = MOCK_DATA.tracks.filter(t => t.album === title);

    const tracksHtml = matchingTracks.length ? matchingTracks.map(t => {
      const idx = MOCK_DATA.tracks.indexOf(t);
      return `
        <div class="detail-list-item" onclick="player.playTrack(${idx}); ui.closeDetailModal()">
          <div style="width:40px;height:40px;border-radius:var(--radius-sm);flex-shrink:0;overflow:hidden">${coverHtml(t)}</div>
          <div style="flex:1;min-width:0">
            <div class="truncate" style="font-weight:var(--weight-medium)">${t.title}</div>
            <div class="truncate text-sm text-secondary">${t.artist}</div>
          </div>
          <div class="text-sm text-tertiary">${t.duration}</div>
        </div>
      `;
    }).join('') : `<p class="text-sm text-secondary">Треки скоро появятся</p>`;

    this.openDetailModal(`
      <div style="display:flex;gap:var(--space-4);align-items:center;margin-bottom:var(--space-5)">
        <div class="cover-gradient ${coverClass}" style="width:80px;height:80px;border-radius:var(--radius-lg);flex-shrink:0"></div>
        <div style="min-width:0">
          <h2 class="truncate" style="font-size:var(--text-xl);font-weight:var(--weight-bold)">${title}</h2>
          <p class="truncate text-sm text-secondary">${subtitle}</p>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--space-2)">${tracksHtml}</div>
    `);
  }

  openLibraryCategory(libCat) {
    const label = libCat.querySelector('.lib-label')?.textContent.trim() || '';

    const dataMap = {
      'Плейлисты': { items: MOCK_DATA.playlists, render: pl => ({ title: pl.title, subtitle: `${pl.tracks} треков`, cover: pl.cover }) },
      'Альбомы': { items: MOCK_DATA.albums, render: al => ({ title: al.title, subtitle: `${al.artist} · ${al.year}`, cover: al.cover }) },
      'Исполнители': { items: MOCK_DATA.artists, render: ar => ({ title: ar.name, subtitle: `${ar.genre} · ${ar.followers} подписчиков`, cover: ar.avatar }) }
    };

    const config = dataMap[label];
    if (!config) {
      // No mock data backs this section yet — be honest instead of faking content
      showToast(`«${label}» — раздел в разработке`);
      return;
    }

    const listHtml = config.items.map(item => {
      const { title, subtitle, cover } = config.render(item);
      const safeTitle = title.replace(/'/g, "\\'");
      return `
        <div class="detail-list-item" onclick="showToast('▶️ Открываем «${safeTitle}»'); ui.closeDetailModal()">
          <div class="cover-gradient ${cover}" style="width:48px;height:48px;border-radius:var(--radius-md);flex-shrink:0"></div>
          <div style="flex:1;min-width:0">
            <div class="truncate" style="font-weight:var(--weight-semibold)">${title}</div>
            <div class="truncate text-sm text-secondary">${subtitle}</div>
          </div>
        </div>
      `;
    }).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">${label}</h2>
      <div style="display:flex;flex-direction:column;gap:var(--space-3)">${listHtml}</div>
    `);
  }

  openSettingDetail(row) {
    const label = row.querySelector('.setting-label')?.textContent.trim() || 'Настройка';
    const sublabel = row.querySelector('.setting-sublabel')?.textContent.trim() || '';

    const richHandlers = {
      'Качество аудио': () => this.renderQualityModal(),
      'Эквалайзер': () => this.renderEqModal(),
      'Устройства': () => this.renderDevicesModal(),
      'Подключенные сервисы': () => this.renderServicesModal(),
      'Безопасность': () => this.renderSecurityModal(),
      'Поделиться профилем': () => this.renderShareModal(sublabel),
      'Синхронизация': () => {
        showToast('🔄 Синхронизация между устройствами включена');
      },
      'Музыкальные комнаты': () => {
        showToast('🎧 Совместное прослушивание — в разработке');
      }
    };

    if (richHandlers[label]) {
      richHandlers[label]();
      return;
    }

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-2)">${label}</h2>
      <p class="text-secondary" style="margin-bottom:var(--space-5)">${sublabel}</p>
      <p class="text-sm text-tertiary">Этот раздел появится в одном из следующих обновлений Never ✨</p>
    `);
  }

  renderQualityModal() {
    const options = [
      { label: 'Низкое', desc: '96 kbps · экономит трафик' },
      { label: 'Среднее', desc: '160 kbps' },
      { label: 'Высокое', desc: '320 kbps · по умолчанию' },
      { label: 'Lossless', desc: 'FLAC · максимальное качество' }
    ];
    const current = MOCK_DATA.nowPlaying.quality;
    const html = options.map(o => `
      <div class="detail-list-item with-action" onclick="ui.selectQuality('${o.label}')">
        <div style="min-width:0">
          <div class="truncate" style="font-weight:var(--weight-semibold)">${o.label}</div>
          <div class="truncate text-sm text-secondary">${o.desc}</div>
        </div>
        ${current.startsWith(o.label) ? '<span style="color:var(--accent-purple);font-size:1.2em">✓</span>' : ''}
      </div>
    `).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">Качество аудио</h2>
      <div style="display:flex;flex-direction:column;gap:var(--space-2)">${html}</div>
    `);
  }

  selectQuality(label) {
    const bitrates = { 'Низкое': '96 kbps', 'Среднее': '160 kbps', 'Высокое': '320 kbps', 'Lossless': 'FLAC' };
    MOCK_DATA.nowPlaying.quality = `${label} (${bitrates[label]})`;
    const sublabelEl = document.querySelector('.setting-label + .setting-sublabel, .setting-sublabel');
    document.querySelectorAll('.setting-row').forEach(row => {
      if (row.querySelector('.setting-label')?.textContent.trim() === 'Качество аудио') {
        row.querySelector('.setting-sublabel').textContent = MOCK_DATA.nowPlaying.quality;
      }
    });
    showToast(`🎚️ Качество: ${label}`);
    this.closeDetailModal();
  }

  renderEqModal() {
    const bands = ['60Hz', '250Hz', '1kHz', '4kHz', '12kHz'];
    const html = bands.map((b, i) => `
      <div class="eq-slider-row">
        <label>${b}</label>
        <input type="range" min="-12" max="12" value="0" oninput="showToast('🎛️ ' + this.previousElementSibling.textContent + ': ' + (this.value>0?'+':'') + this.value + ' dB')">
      </div>
    `).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-1)">Эквалайзер</h2>
      <p class="text-sm text-secondary" style="margin-bottom:var(--space-5)">Пользовательский пресет</p>
      ${html}
    `);
  }

  renderDevicesModal() {
    const html = MOCK_DATA.devices.map(d => `
      <div class="detail-list-item with-action" id="device-${d.id}">
        <div style="min-width:0">
          <div class="truncate" style="font-weight:var(--weight-semibold)">${d.name}${d.current ? ' · это устройство' : ''}</div>
          <div class="truncate text-sm text-secondary">${d.type} · ${d.lastActive}</div>
        </div>
        ${d.current ? '' : `<span class="detail-action-btn danger" onclick="event.stopPropagation(); ui.revokeDevice(${d.id})">Завершить</span>`}
      </div>
    `).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">Устройства</h2>
      <div style="display:flex;flex-direction:column;gap:var(--space-2)" id="devices-list">${html}</div>
    `);
  }

  revokeDevice(id) {
    MOCK_DATA.devices = MOCK_DATA.devices.filter(d => d.id !== id);
    const el = document.getElementById(`device-${id}`);
    if (el) el.remove();
    document.querySelectorAll('.setting-row').forEach(row => {
      if (row.querySelector('.setting-label')?.textContent.trim() === 'Устройства') {
        row.querySelector('.setting-sublabel').textContent = `${MOCK_DATA.devices.length} подключенных устройства`;
        const badge = row.querySelector('.badge');
        if (badge) badge.textContent = MOCK_DATA.devices.length;
      }
    });
    showToast('🔒 Сеанс завершён на устройстве');
  }

  renderServicesModal() {
    const html = MOCK_DATA.connectedServices.map(s => `
      <div class="detail-list-item with-action" id="service-${s.id}">
        <div style="min-width:0">
          <div class="truncate" style="font-weight:var(--weight-semibold)">${s.name}</div>
          <div class="truncate text-sm text-secondary">${s.desc}</div>
        </div>
        <span class="detail-action-btn ${s.connected ? 'connected' : 'connect'}" onclick="event.stopPropagation(); ui.toggleService('${s.id}')">
          ${s.connected ? 'Отключить' : 'Подключить'}
        </span>
      </div>
    `).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">Подключенные сервисы</h2>
      <div style="display:flex;flex-direction:column;gap:var(--space-2)">${html}</div>
    `);
  }

  toggleService(id) {
    const service = MOCK_DATA.connectedServices.find(s => s.id === id);
    if (!service) return;
    service.connected = !service.connected;
    this.renderServicesModal();

    const connectedNames = MOCK_DATA.connectedServices.filter(s => s.connected).map(s => s.name).join(', ');
    document.querySelectorAll('.setting-row').forEach(row => {
      if (row.querySelector('.setting-label')?.textContent.trim() === 'Подключенные сервисы') {
        row.querySelector('.setting-sublabel').textContent = connectedNames || 'Ничего не подключено';
      }
    });
    showToast(service.connected ? `🔗 ${service.name} подключён` : `⛓️‍💥 ${service.name} отключён`);
  }

  renderSecurityModal() {
    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">Безопасность</h2>
      <div class="auth-field" style="margin-bottom:var(--space-3)">
        <label>Текущий пароль</label>
        <input type="password" id="sec-current-pw" placeholder="••••••••">
      </div>
      <div class="auth-field" style="margin-bottom:var(--space-3)">
        <label>Новый пароль</label>
        <input type="password" id="sec-new-pw" placeholder="Минимум 6 символов" minlength="6">
      </div>
      <button class="auth-submit" style="width:100%;margin-top:var(--space-2)" onclick="ui.changePassword()">Сохранить пароль</button>
      <p class="text-sm text-tertiary" style="margin-top:var(--space-5)">Двухфакторная аутентификация и история входов появятся здесь в следующем обновлении.</p>
    `);
  }

  changePassword() {
    const current = document.getElementById('sec-current-pw')?.value || '';
    const next = document.getElementById('sec-new-pw')?.value || '';
    const session = auth.getSession();

    if (!session || session.provider !== 'email') {
      showToast('Смена пароля доступна только для входа по email');
      return;
    }
    if (next.length < 6) {
      showToast('Новый пароль должен быть от 6 символов');
      return;
    }
    const users = auth.getUsers();
    const user = users.find(u => u.email === session.email);
    if (!user || user.passwordHash !== auth.hash(current)) {
      showToast('Текущий пароль указан неверно');
      return;
    }
    user.passwordHash = auth.hash(next);
    auth.saveUsers(users);
    showToast('🔒 Пароль обновлён');
    this.closeDetailModal();
  }

  renderShareModal(link) {
    const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=10&data=${encodeURIComponent('https://' + link)}`;
    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4);text-align:center">Поделиться профилем</h2>
      <div style="display:flex;justify-content:center;margin-bottom:var(--space-5)">
        <div style="background:#fff;padding:var(--space-3);border-radius:var(--radius-lg);box-shadow:var(--shadow-md)">
          <img src="${qrUrl}" width="180" height="180" alt="QR-код профиля" style="display:block;border-radius:var(--radius-sm)">
        </div>
      </div>
      <div class="detail-list-item" style="background:var(--bg-surface);border-radius:var(--radius-md);cursor:default">
        <div class="truncate" style="flex:1">${link}</div>
      </div>
      <button class="auth-submit" style="width:100%;margin-top:var(--space-4)" onclick="ui.copyShareLink('${link}')">Скопировать ссылку</button>
    `);
  }

  copyShareLink(link) {
    if (navigator.clipboard) {
      navigator.clipboard.writeText(`https://${link}`).then(() => showToast('🔗 Ссылка скопирована'));
    } else {
      showToast('🔗 ' + link);
    }
    this.closeDetailModal();
  }

  // ── Appearance toggles (theme / glassmorphism / animations) ──
  // Each toggle below is the SINGLE source of truth for its own
  // state: it reads its own current visual state, flips it, and
  // applies both the visual class and the real effect together —
  // so there's no way for the switch and the actual effect to
  // drift out of sync.
  setupAppearanceToggles() {
    const bounce = (el) => {
      el.style.transform = 'scale(0.9)';
      setTimeout(() => { el.style.transform = 'scale(1)'; }, 150);
    };

    // Theme
    const themeToggle = document.getElementById('toggle-theme');
    if (themeToggle) {
      const savedTheme = localStorage.getItem('vibe_theme') || 'light';
      const applyTheme = (dark) => {
        document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
        themeToggle.classList.toggle('active', dark);
        localStorage.setItem('vibe_theme', dark ? 'dark' : 'light');
      };
      applyTheme(savedTheme === 'dark');
      themeToggle.addEventListener('click', () => {
        const goingDark = !themeToggle.classList.contains('active');
        applyTheme(goingDark);
        bounce(themeToggle);
        showToast(goingDark ? '🌙 Тёмная тема' : '☀️ Светлая тема');
      });
    }

    // Glassmorphism (transparency)
    const glassToggle = document.getElementById('toggle-glass');
    if (glassToggle) {
      const savedGlass = localStorage.getItem('vibe_glass') !== 'off'; // default: on
      const applyGlass = (enabled) => {
        document.documentElement.classList.toggle('no-glass', !enabled);
        glassToggle.classList.toggle('active', enabled);
        localStorage.setItem('vibe_glass', enabled ? 'on' : 'off');
      };
      applyGlass(savedGlass);
      glassToggle.addEventListener('click', () => {
        const enabling = !glassToggle.classList.contains('active');
        applyGlass(enabling);
        bounce(glassToggle);
      });
    }

    // Animations
    const animToggle = document.getElementById('toggle-animations');
    if (animToggle) {
      const savedAnims = localStorage.getItem('vibe_animations') !== 'off'; // default: on
      const applyAnims = (enabled) => {
        document.documentElement.classList.toggle('no-animations', !enabled);
        animToggle.classList.toggle('active', enabled);
        localStorage.setItem('vibe_animations', enabled ? 'on' : 'off');
      };
      applyAnims(savedAnims);
      animToggle.addEventListener('click', () => {
        const enabling = !animToggle.classList.contains('active');
        applyAnims(enabling);
        bounce(animToggle);
      });
    }
  }

  // ── "Все" / "Топ 100" / "Карта" section links ──
  setupSectionActions() {
    document.addEventListener('click', (e) => {
      const action = e.target.closest('.section-action');
      if (!action) return;
      const header = action.closest('.section-header');
      const title = header?.querySelector('.section-title')?.textContent.trim();
      if (!title) return;

      if (title === 'Концерты рядом') {
        const venues = MOCK_DATA.concerts.map(c => `${c.venue}, ${c.city}`).join(' | ');
        window.open(`https://www.google.com/maps/search/${encodeURIComponent(venues)}`, '_blank');
        return;
      }

      const map = {
        'Продолжить': { items: MOCK_DATA.tracks.slice(0, 6), type: 'track' },
        'Новые релизы': { items: MOCK_DATA.albums, type: 'album' },
        'Популярное': { items: MOCK_DATA.tracks, type: 'track' },
        'Недавно слушали': { items: MOCK_DATA.artists, type: 'artist' },
        'Плейлисты дня': { items: MOCK_DATA.playlists, type: 'playlist' },
        'Похожие исполнители': { items: MOCK_DATA.artists, type: 'artist' },
        'Новое от любимых': { items: MOCK_DATA.albums, type: 'album' }
      };
      const config = map[title];
      if (!config) {
        showToast(`«${title}» — полный список скоро будет доступен`);
        return;
      }
      this.openListModal(title, config.items, config.type);
    });
  }

  openListModal(title, items, type) {
    const renderers = {
      track: t => ({ cover: t.cover, title: t.title, subtitle: t.artist, onClick: `player.playTrack(${MOCK_DATA.tracks.indexOf(t)}); ui.closeDetailModal()` }),
      album: a => ({ cover: a.cover, title: a.title, subtitle: a.artist, onClick: `showToast('💿 Открываем «${a.title.replace(/'/g, "\\'")}»'); ui.closeDetailModal()` }),
      artist: ar => ({ cover: ar.avatar, title: ar.name, subtitle: `${ar.genre} · ${ar.followers}`, onClick: `showToast('👤 Открываем ${ar.name.replace(/'/g, "\\'")}'); ui.closeDetailModal()` }),
      playlist: pl => ({ cover: pl.cover, title: pl.title, subtitle: `${pl.tracks} треков`, onClick: `player.playTrack(0); ui.closeDetailModal()` })
    };
    const renderer = renderers[type];
    const html = items.map(item => {
      const { cover, title: t, subtitle, onClick } = renderer(item);
      return `
        <div class="detail-list-item" onclick="${onClick}">
          <div class="cover-gradient ${cover}" style="width:48px;height:48px;border-radius:var(--radius-md);flex-shrink:0"></div>
          <div style="flex:1;min-width:0">
            <div class="truncate" style="font-weight:var(--weight-semibold)">${t}</div>
            <div class="truncate text-sm text-secondary">${subtitle}</div>
          </div>
        </div>
      `;
    }).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">${title}</h2>
      <div style="display:flex;flex-direction:column;gap:var(--space-3);max-height:60vh;overflow-y:auto">${html}</div>
    `);
  }

  // ── Player "Queue" and "..." menu (previously dead buttons) ──
  renderQueueModal() {
    const current = MOCK_DATA.nowPlaying.trackIndex;
    const upcoming = [];
    for (let i = 1; i <= MOCK_DATA.tracks.length - 1; i++) {
      upcoming.push(MOCK_DATA.tracks[(current + i) % MOCK_DATA.tracks.length]);
    }
    const html = upcoming.slice(0, 10).map(t => {
      const idx = MOCK_DATA.tracks.indexOf(t);
      return `
        <div class="detail-list-item" onclick="player.playTrack(${idx}); ui.closeDetailModal()">
          <div style="width:44px;height:44px;border-radius:var(--radius-sm);flex-shrink:0;overflow:hidden">${coverHtml(t)}</div>
          <div style="flex:1;min-width:0">
            <div class="truncate" style="font-weight:var(--weight-medium)">${t.title}</div>
            <div class="truncate text-sm text-secondary">${t.artist}</div>
          </div>
          <div class="text-sm text-tertiary">${t.duration}</div>
        </div>
      `;
    }).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-1)">Очередь</h2>
      <p class="text-sm text-secondary" style="margin-bottom:var(--space-4)">Сейчас играет: ${getCurrentTrack().title}</p>
      <div style="display:flex;flex-direction:column;gap:var(--space-2)">${html}</div>
    `);
  }

  renderTrackMoreModal() {
    const track = getCurrentTrack();
    const playlistOptions = MOCK_DATA.playlists.map(pl => `
      <div class="detail-list-item" onclick="ui.addToPlaylist('${pl.id}')">
        <div class="cover-gradient ${pl.cover}" style="width:40px;height:40px;border-radius:var(--radius-sm);flex-shrink:0"></div>
        <div class="truncate" style="font-weight:var(--weight-medium)">${pl.title}</div>
      </div>
    `).join('');

    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-1)">${track.title}</h2>
      <p class="text-sm text-secondary" style="margin-bottom:var(--space-4)">${track.artist}</p>
      <div class="detail-list-item" onclick="ui.shareTrack()">
        <span style="font-size:1.3em">🔗</span>
        <div class="truncate" style="font-weight:var(--weight-medium)">Поделиться треком</div>
      </div>
      <div class="detail-list-item" onclick="showToast('👤 Переход к исполнителю ${track.artist.replace(/'/g, "\\'")}'); ui.closeDetailModal()">
        <span style="font-size:1.3em">👤</span>
        <div class="truncate" style="font-weight:var(--weight-medium)">Перейти к исполнителю</div>
      </div>
      <p class="text-sm text-secondary" style="margin:var(--space-4) 0 var(--space-2)">Добавить в плейлист:</p>
      <div style="display:flex;flex-direction:column;gap:var(--space-2);max-height:35vh;overflow-y:auto">${playlistOptions}</div>
    `);
  }

  addToPlaylist(playlistId) {
    const pl = MOCK_DATA.playlists.find(p => String(p.id) === String(playlistId));
    if (pl) {
      pl.tracks += 1;
      showToast(`➕ Добавлено в «${pl.title}»`);
    }
    this.closeDetailModal();
  }

  shareTrack() {
    const track = getCurrentTrack();
    const link = `vibe.app/track/${track.id}`;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(`https://${link}`).then(() => showToast('🔗 Ссылка на трек скопирована'));
    } else {
      showToast('🔗 ' + link);
    }
    this.closeDetailModal();
  }

  // ── Library search (real client-side filter) ──
  setupLibrarySearch() {
    const input = document.getElementById('library-search-input');
    if (!input) return;
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      document.querySelectorAll('#playlist-grid .playlist-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = (!q || text.includes(q)) ? '' : 'none';
      });
      document.querySelectorAll('#liked-tracks-list .track-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = (!q || text.includes(q)) ? '' : 'none';
      });
    });
  }

  // ── Profile screen: edit profile + avatar + subscription ──
  setupProfileButtons() {
    const editBtn = document.querySelector('.btn-ghost');
    if (editBtn) {
      editBtn.addEventListener('click', () => this.renderEditProfileModal());
    }

    const editBadge = document.querySelector('.edit-badge');
    if (editBadge) {
      editBadge.addEventListener('click', (e) => {
        e.stopPropagation();
        const gradients = ['artist-1', 'artist-2', 'artist-3', 'artist-4', 'artist-5', 'artist-6', 'cover-1', 'cover-3', 'cover-5'];
        const avatarEl = document.querySelector('.avatar-xl .cover-gradient');
        if (!avatarEl) return;
        const current = gradients.find(g => avatarEl.classList.contains(g)) || gradients[0];
        const next = gradients[(gradients.indexOf(current) + 1) % gradients.length];
        avatarEl.classList.remove(current);
        avatarEl.classList.add(next);
        showToast('🎨 Аватар обновлён');
      });
    }

    const subCard = document.querySelector('.sub-card');
    if (subCard) {
      subCard.addEventListener('click', () => this.renderSubscriptionModal());
    }
  }

  renderEditProfileModal() {
    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-4)">Редактировать профиль</h2>
      <div class="auth-field" style="margin-bottom:var(--space-3)">
        <label>Имя</label>
        <input type="text" id="edit-profile-name" value="${MOCK_DATA.user.name}">
      </div>
      <div class="auth-field" style="margin-bottom:var(--space-4)">
        <label>Никнейм</label>
        <input type="text" id="edit-profile-handle" value="${MOCK_DATA.user.handle}">
      </div>
      <button class="auth-submit" style="width:100%" onclick="ui.saveProfile()">Сохранить</button>
    `);
  }

  saveProfile() {
    const name = document.getElementById('edit-profile-name')?.value.trim();
    const handle = document.getElementById('edit-profile-handle')?.value.trim();
    if (name) MOCK_DATA.user.name = name;
    if (handle) MOCK_DATA.user.handle = handle;

    const nameEl = document.querySelector('.profile-name');
    const handleEl = document.querySelector('.profile-handle');
    if (nameEl) nameEl.textContent = MOCK_DATA.user.name;
    if (handleEl) handleEl.textContent = MOCK_DATA.user.handle;
    if (typeof app !== 'undefined') app.populateHome();

    showToast('✅ Профиль обновлён');
    this.closeDetailModal();
  }

  renderSubscriptionModal() {
    this.openDetailModal(`
      <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-bottom:var(--space-1)">${MOCK_DATA.user.subscription.plan}</h2>
      <p class="text-sm text-secondary" style="margin-bottom:var(--space-5)">Активна до ${MOCK_DATA.user.subscription.expires}</p>
      <div class="detail-list-item" onclick="showToast('💳 Управление способом оплаты появится позже')">
        <span style="font-size:1.3em">💳</span>
        <div class="truncate" style="font-weight:var(--weight-medium)">Способ оплаты</div>
      </div>
      <div class="detail-list-item" onclick="ui.cancelSubscription()">
        <span style="font-size:1.3em">❌</span>
        <div class="truncate" style="font-weight:var(--weight-medium);color:var(--color-error)">Отменить подписку</div>
      </div>
    `);
  }

  cancelSubscription() {
    if (!confirm('Отменить Never Premium? Доступ сохранится до конца оплаченного периода.')) return;
    showToast('Подписка будет отменена в конце периода');
    this.closeDetailModal();
  }

  // ── Concert cards (both the static promo card and dynamic list) ──
  setupConcertCards() {
    document.addEventListener('click', (e) => {
      const card = e.target.closest('.concert-card');
      if (!card) return;

      if (card.id === 'support-artist-card') {
        showToast('💜 Донаты артистам появятся в одном из следующих обновлений');
        return;
      }

      const venue = card.querySelector('.concert-venue')?.textContent.trim();
      const city = card.querySelector('.concert-city')?.textContent.replace('📍', '').trim();
      if (venue) {
        window.open(`https://www.google.com/maps/search/${encodeURIComponent(venue + ' ' + (city || ''))}`, '_blank');
      } else {
        showToast('🎟️ Билеты скоро можно будет купить прямо в Never');
      }
    });
  }
}

// Create global UI instance
const ui = new VibeUI();


// ============================================
// Never — Main Application
// ============================================

class VibeApp {
  constructor() {
    this.initialized = false;
  }

  init() {
    if (this.initialized) return;

    // Restore appearance preferences (theme / glass / animations)
    ui.setupAppearanceToggles();

    // Initialize modules
    router.init();
    player.init();
    ui.init();

    // Setup router callbacks
    router.onTabChange = (tab, prevTab) => {
      // Re-animate passport counters on profile tab
      if (tab === 'profile') {
        setTimeout(() => {
          const counters = document.querySelectorAll('.passport-stat-value');
          const values = [MOCK_DATA.user.passport.hoursListened, MOCK_DATA.user.passport.tracksPlayed];
          counters.forEach((el, i) => {
            if (values[i]) ui.animateCounter(el, values[i]);
          });
        }, 300);
      }
    };

    // Populate dynamic content
    this.populateHome();
    this.populateForYou();
    this.populateLibrary();
    this.populateProfile();
    this.populateLyrics();

    // Handle keyboard
    document.addEventListener('keydown', (e) => {
      if (e.code === 'Space' && !e.target.matches('input, textarea')) {
        e.preventDefault();
        player.togglePlay();
      }
      if (e.code === 'ArrowRight') player.nextTrack();
      if (e.code === 'ArrowLeft') player.prevTrack();
      if (e.code === 'Escape') {
        if (player.lyricsOpen) player.toggleLyrics();
        else if (player.isPlayerOpen) player.closePlayer();
      }
    });

    this.initialized = true;
    console.log('🎵 Never initialized successfully');

    this.loadAudiusTracks();
  }

  // Fetches real, actually-playable tracks from Audius and puts them
  // at the front of the catalog, then re-renders so they show up
  // everywhere (Home, Library, mini-player defaults to track 0, etc.)
  async loadAudiusTracks() {
    try {
      const tracks = await audiusFetchTrending(12);
      if (!tracks.length) return;

      MOCK_DATA.tracks = [...tracks, ...MOCK_DATA.tracks];

      this.populateHome();
      this.populateForYou();
      this.populateLibrary();

      setTimeout(() => {
        ui.setupTrackClicks();
        ui.setupLikeButtons();
      }, 50);

      showToast(`🎧 Загружено ${tracks.length} реальных треков из Audius`);
    } catch (err) {
      console.error('Audius fetch failed:', err);
      showToast('⚠️ Не удалось загрузить треки из Audius — проверьте интернет-соединение');
    }
  }

  populateHome() {
    // Greeting
    const greetingEl = document.getElementById('home-greeting');
    if (greetingEl) {
      greetingEl.innerHTML = `${getGreeting()}, ${MOCK_DATA.user.name} <span class="wave-emoji">👋</span>`;
    }

    const dateEl = document.getElementById('home-date');
    if (dateEl) {
      dateEl.textContent = getFormattedDate();
    }

    // Continue Listening
    const continueGrid = document.getElementById('continue-grid');
    if (continueGrid) {
      continueGrid.innerHTML = MOCK_DATA.tracks.slice(0, 6).map((track, i) => `
        <div class="continue-card card-stagger" data-track-index="${i}" onclick="player.playTrack(${i})">
          <div class="continue-card-cover">
            ${coverHtml(track)}
          </div>
          <div class="continue-card-info">
            <div class="continue-card-title">${track.title}</div>
            <div class="continue-card-artist">${track.artist}</div>
          </div>
        </div>
      `).join('');
    }

    // New Releases
    const newReleases = document.getElementById('new-releases');
    if (newReleases) {
      newReleases.innerHTML = MOCK_DATA.albums.map(album => {
        const trackIdx = Math.max(0, MOCK_DATA.tracks.findIndex(t => t.album === album.title));
        return `
        <div class="album-card card-stagger">
          <div class="album-card-cover">
            <div class="cover-gradient ${album.cover}"></div>
            <div class="play-fab" onclick="event.stopPropagation(); player.playTrack(${trackIdx})">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
          <div class="album-card-title">${album.title}</div>
          <div class="album-card-subtitle">${album.artist}</div>
        </div>
      `;
      }).join('');
    }

    // Popular tracks
    const popularTracks = document.getElementById('popular-tracks');
    if (popularTracks) {
      popularTracks.innerHTML = MOCK_DATA.tracks.slice(0, 5).map((track, i) => `
        <div class="track-card ripple-effect" data-track-index="${i}">
          <div class="track-number">${i + 1}</div>
          <div class="track-cover">
            ${coverHtml(track)}
          </div>
          <div class="track-info">
            <div class="track-title">${track.title}${track.source==="soundcloud" ? ' <span title="Реальное аудио" style="opacity:.5">●</span>' : ''}</div>
            <div class="track-artist">${track.artist}</div>
          </div>
          <div class="track-duration">${track.duration}</div>
          <button class="icon-btn like-btn ${track.liked ? 'liked' : ''}" aria-label="Нравится">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
      `).join('');
    }

    // Recently listened artists
    const recentArtists = document.getElementById('recent-artists');
    if (recentArtists) {
      recentArtists.innerHTML = MOCK_DATA.artists.map(artist => `
        <div class="artist-circle card-stagger">
          <div class="artist-circle-img">
            <div class="cover-gradient ${artist.avatar}"></div>
          </div>
          <div class="artist-circle-name">${artist.name}</div>
        </div>
      `).join('');
    }

    // Recommended albums
    const recAlbums = document.getElementById('rec-albums');
    if (recAlbums) {
      recAlbums.innerHTML = MOCK_DATA.albums.slice(3, 8).map(album => {
        const trackIdx = Math.max(0, MOCK_DATA.tracks.findIndex(t => t.album === album.title));
        return `
        <div class="album-card card-stagger">
          <div class="album-card-cover">
            <div class="cover-gradient ${album.cover}"></div>
            <div class="play-fab" onclick="event.stopPropagation(); player.playTrack(${trackIdx})">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
          <div class="album-card-title">${album.title}</div>
          <div class="album-card-subtitle">${album.artist} · ${album.year}</div>
        </div>
      `;
      }).join('');
    }

    // Playlists
    const dayPlaylists = document.getElementById('day-playlists');
    if (dayPlaylists) {
      dayPlaylists.innerHTML = MOCK_DATA.playlists.slice(0, 4).map(pl => `
        <div class="album-card card-stagger">
          <div class="album-card-cover">
            <div class="cover-gradient ${pl.gradient}"></div>
            <div class="play-fab" onclick="event.stopPropagation(); player.playTrack(0)">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
          <div class="album-card-title">${pl.title}</div>
          <div class="album-card-subtitle">${pl.tracks} треков</div>
        </div>
      `).join('');
    }
  }

  populateForYou() {
    // Mood cards
    const moodGrid = document.getElementById('mood-grid');
    if (moodGrid) {
      moodGrid.innerHTML = MOCK_DATA.moods.map(mood => `
        <div class="mood-card card-stagger" style="background: ${mood.gradient}">
          <span class="mood-card-icon">${mood.icon}</span>
          <span class="mood-card-label">${mood.label}</span>
        </div>
      `).join('');
    }

    // Time of day
    const timeCard = document.getElementById('time-card');
    const tod = getTimeOfDay();
    if (timeCard) {
      timeCard.style.background = tod.gradient;
      timeCard.innerHTML = `
        <div class="time-card-content">
          <div class="time-card-label">${tod.label}</div>
          <div class="time-card-title">${tod.title}</div>
          <div class="time-card-desc">${tod.desc}</div>
        </div>
      `;
    }

    // Genres
    const genreBubbles = document.getElementById('genre-bubbles');
    if (genreBubbles) {
      genreBubbles.innerHTML = MOCK_DATA.genres.map(genre => `
        <div class="genre-bubble" style="background: ${genre.bg}; color: ${genre.color}; border-color: ${genre.color}30">${genre.name}</div>
      `).join('');
    }

    // Similar artists
    const simArtists = document.getElementById('sim-artists');
    if (simArtists) {
      simArtists.innerHTML = MOCK_DATA.artists.map(artist => `
        <div class="artist-circle card-stagger">
          <div class="artist-circle-img">
            <div class="cover-gradient ${artist.avatar}"></div>
          </div>
          <div class="artist-circle-name">${artist.name}</div>
        </div>
      `).join('');
    }

    // New from favorites
    const newFavs = document.getElementById('new-favs');
    if (newFavs) {
      newFavs.innerHTML = MOCK_DATA.albums.slice(0, 5).map(album => {
        const trackIdx = Math.max(0, MOCK_DATA.tracks.findIndex(t => t.album === album.title));
        return `
        <div class="album-card card-stagger">
          <div class="album-card-cover">
            <div class="cover-gradient ${album.cover}"></div>
            <div class="play-fab" onclick="event.stopPropagation(); player.playTrack(${trackIdx})">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
          <div class="album-card-title">${album.title}</div>
          <div class="album-card-subtitle">${album.artist}</div>
        </div>
      `;
      }).join('');
    }

    // AI Recommended tracks
    const aiTracks = document.getElementById('ai-tracks');
    if (aiTracks) {
      aiTracks.innerHTML = MOCK_DATA.tracks.slice(5, 10).map((track, i) => `
        <div class="track-card ripple-effect" data-track-index="${i + 5}">
          <div class="track-cover">
            ${coverHtml(track)}
          </div>
          <div class="track-info">
            <div class="track-title">${track.title}${track.source==="soundcloud" ? ' <span title="Реальное аудио" style="opacity:.5">●</span>' : ''}</div>
            <div class="track-artist">${track.artist}</div>
          </div>
          <div class="track-duration">${track.duration}</div>
          <button class="icon-btn like-btn ${track.liked ? 'liked' : ''}" aria-label="Нравится">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
      `).join('');
    }

    // Concerts
    const concertsList = document.getElementById('concerts-list');
    if (concertsList) {
      concertsList.innerHTML = MOCK_DATA.concerts.map(concert => `
        <div class="concert-card card-stagger">
          <div class="concert-date">
            <div class="concert-day">${concert.day}</div>
            <div class="concert-month">${concert.month}</div>
          </div>
          <div class="concert-info">
            <div class="concert-name">${concert.artist}</div>
            <div class="concert-venue">${concert.venue}</div>
            <div class="concert-city">📍 ${concert.city}</div>
          </div>
        </div>
      `).join('');
    }
  }

  populateLibrary() {
    // Update liked count dynamically
    const likedCount = document.getElementById('liked-count');
    if (likedCount) {
      const count = MOCK_DATA.tracks.filter(t => t.liked).length;
      likedCount.textContent = `${count} треков`;
    }

    // Playlist grid
    const playlistGrid = document.getElementById('playlist-grid');
    if (playlistGrid) {
      const playlists = MOCK_DATA.playlists.map(pl => `
        <div class="playlist-card card-stagger">
          <div class="cover-gradient ${pl.gradient}"></div>
          <div class="playlist-card-info">
            <div class="playlist-card-title">${pl.title}</div>
            <div class="playlist-card-count">${pl.tracks} треков</div>
          </div>
        </div>
      `).join('');

      const createBtn = `
        <div class="create-playlist-btn">
          <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span>Создать</span>
        </div>
      `;

      playlistGrid.innerHTML = playlists + createBtn;
    }

    // Liked tracks
    const likedTracks = document.getElementById('liked-tracks-list');
    if (likedTracks) {
      likedTracks.innerHTML = MOCK_DATA.tracks.filter(t => t.liked).map((track, i) => `
        <div class="track-card ripple-effect" data-track-index="${MOCK_DATA.tracks.indexOf(track)}">
          <div class="track-cover">
            ${coverHtml(track)}
          </div>
          <div class="track-info">
            <div class="track-title">${track.title}${track.source==="soundcloud" ? ' <span title="Реальное аудио" style="opacity:.5">●</span>' : ''}</div>
            <div class="track-artist">${track.artist}</div>
          </div>
          <div class="track-duration">${track.duration}</div>
          <button class="icon-btn like-btn liked" aria-label="Нравится">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
      `).join('');
    }
  }

  populateProfile() {
    // Passport counters will be animated when the tab is opened
    const passportHours = document.getElementById('passport-hours');
    const passportTracks = document.getElementById('passport-tracks');

    if (passportHours) passportHours.textContent = '0';
    if (passportTracks) passportTracks.textContent = '0';
  }

  populateLyrics() {
    const lyricsContent = document.getElementById('lyrics-content');
    if (lyricsContent) {
      lyricsContent.innerHTML = MOCK_DATA.lyrics.map((lyric, i) => {
        if (!lyric.text) return '<div class="lyrics-line" style="height: 24px"></div>';
        return `<div class="lyrics-line ${i === 0 ? 'active' : ''}">${lyric.text}</div>`;
      }).join('');
    }
  }
}

// Initialize app when DOM is ready
let app;

document.addEventListener('DOMContentLoaded', () => {
  app = new VibeApp();

  auth.init(() => {
    app.init();

    // Re-init UI interactions after dynamic content
    setTimeout(() => {
      ui.setupRippleEffect();
      ui.setupTrackClicks();
      ui.setupLikeButtons();
      ui.setupParallaxCovers();
    }, 100);
  });
});

  </script>
</body>
</html>
