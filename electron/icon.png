<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="description" content="Never — музыкальная платформа нового поколения. Слушай музыку, открывай новое, делись с друзьями.">
  <meta name="theme-color" content="#0A0A12">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Never — Музыка нового поколения</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->





  <!-- Firebase (used only once FIREBASE_CONFIG in the auth script has
       real keys — see the comment at the top of that section. Safe to
       load even before that: it just sits unused in demo mode. -->
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>

  <!-- Favicon (inline SVG) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎵</text></svg>">
  <style>
/* ============================================
   NEVER — Design System Tokens
   Monochrome: dark theme = black & white,
   light theme = white & black.
   ============================================ */

:root {
  /* ── Color Palette (DARK theme = default) ── */

  /* Backgrounds */
  --bg-deepest: #0A0A0A;
  --bg-deep: #0D0D0D;
  --bg-primary: #121212;
  --bg-secondary: #161616;
  --bg-elevated: #1C1C1C;
  --bg-surface: #202020;
  --bg-hover: #2A2A2A;

  /* Accent — monochrome: white pops on dark */
  --accent-purple: #FFFFFF;
  --accent-blue: #E5E5E5;
  --accent-cyan: #CFCFCF;
  --accent-gradient: linear-gradient(135deg, #FFFFFF 0%, #D4D4D4 100%);
  --accent-gradient-vibrant: linear-gradient(135deg, #FFFFFF 0%, #C9C9C9 100%);
  --accent-gradient-warm: linear-gradient(135deg, #FFFFFF 0%, #BFBFBF 100%);
  --accent-gradient-horizontal: linear-gradient(90deg, #FFFFFF 0%, #C9C9C9 100%);

  /* "Neon" / Glow — soft neutral glow instead of color */
  --neon-purple: #FFFFFF;
  --neon-blue: #E5E5E5;
  --neon-pink: #D4D4D4;
  --neon-cyan: #CFCFCF;
  --glow-purple: rgba(255, 255, 255, 0.14);
  --glow-blue: rgba(255, 255, 255, 0.10);
  --glow-pink: rgba(255, 255, 255, 0.10);

  /* Text */
  --text-primary: #FFFFFF;
  --text-secondary: #A3A3A3;
  --text-tertiary: #737373;
  --text-muted: #464646;
  --text-accent: #FFFFFF;

  /* Semantic — kept as the only real colors in the whole system */
  --color-success: #22C55E;
  --color-warning: #EAB308;
  --color-error: #EF4444;
  --color-info: #A3A3A3;

  /* Borders */
  --border-subtle: rgba(255, 255, 255, 0.08);
  --border-default: rgba(255, 255, 255, 0.14);
  --border-accent: rgba(255, 255, 255, 0.4);

  /* ── Typography ────────────────────────── */
  --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', 'Cascadia Code', monospace;

  /* Font Sizes */
  --text-xs: 0.6875rem;    /* 11px */
  --text-sm: 0.8125rem;    /* 13px */
  --text-base: 0.9375rem;  /* 15px */
  --text-md: 1rem;         /* 16px */
  --text-lg: 1.125rem;     /* 18px */
  --text-xl: 1.3125rem;    /* 21px */
  --text-2xl: 1.625rem;    /* 26px */
  --text-3xl: 2rem;        /* 32px */
  --text-4xl: 2.5rem;      /* 40px */
  --text-hero: 3.5rem;     /* 56px */

  /* Font Weights */
  --weight-light: 300;
  --weight-normal: 400;
  --weight-medium: 500;
  --weight-semibold: 600;
  --weight-bold: 700;
  --weight-extrabold: 800;
  --weight-black: 900;

  /* Line Heights */
  --leading-tight: 1.15;
  --leading-snug: 1.3;
  --leading-normal: 1.5;
  --leading-relaxed: 1.65;

  /* Letter Spacing */
  --tracking-tight: -0.025em;
  --tracking-normal: 0;
  --tracking-wide: 0.025em;
  --tracking-wider: 0.05em;
  --tracking-widest: 0.1em;

  /* ── Spacing ───────────────────────────── */
  --space-1: 0.25rem;
  --space-2: 0.5rem;
  --space-3: 0.75rem;
  --space-4: 1rem;
  --space-5: 1.25rem;
  --space-6: 1.5rem;
  --space-8: 2rem;
  --space-10: 2.5rem;
  --space-12: 3rem;
  --space-16: 4rem;
  --space-20: 5rem;

  /* ── Borders & Radius ──────────────────── */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-2xl: 24px;
  --radius-3xl: 32px;
  --radius-full: 9999px;

  /* ── Shadows — soft neutral, no color tint ── */
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.6);
  --shadow-glow-purple: 0 0 20px rgba(255, 255, 255, 0.12), 0 0 60px rgba(255, 255, 255, 0.05);
  --shadow-glow-blue: 0 0 20px rgba(255, 255, 255, 0.10), 0 0 60px rgba(255, 255, 255, 0.04);
  --shadow-glow-accent: 0 4px 20px rgba(255, 255, 255, 0.10), 0 0 40px rgba(255, 255, 255, 0.05);
  --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.4), 0 0 1px rgba(255, 255, 255, 0.05);

  /* ── Glassmorphism ─────────────────────── */
  --glass-bg: rgba(18, 18, 18, 0.70);
  --glass-bg-light: rgba(28, 28, 28, 0.55);
  --glass-bg-heavy: rgba(10, 10, 10, 0.85);
  --glass-blur: blur(24px);
  --glass-blur-light: blur(12px);
  --glass-blur-heavy: blur(40px);
  --glass-border: 1px solid rgba(255, 255, 255, 0.08);
  --glass-border-accent: 1px solid rgba(255, 255, 255, 0.16);

  /* ── Animation Curves ──────────────────── */
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-spring-soft: cubic-bezier(0.22, 1.2, 0.36, 1);
  --ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-in: cubic-bezier(0.4, 0, 1, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);

  /* Animation Durations — a bit snappier/calmer than before */
  --duration-fast: 120ms;
  --duration-normal: 200ms;
  --duration-medium: 280ms;
  --duration-slow: 380ms;
  --duration-slower: 550ms;
  --duration-slowest: 800ms;

  /* ── Z-Index Scale ─────────────────────── */
  --z-base: 1;
  --z-dropdown: 10;
  --z-sticky: 20;
  --z-overlay: 30;
  --z-modal: 40;
  --z-mini-player: 50;
  --z-nav: 60;
  --z-player: 70;
  --z-toast: 80;
  --z-tooltip: 90;
  --z-max: 100;

  /* ── Layout ────────────────────────────── */
  --nav-height: 72px;
  --mini-player-height: 64px;
  --status-bar-height: env(safe-area-inset-top, 0px);
  --bottom-safe: env(safe-area-inset-bottom, 0px);
  --content-max-width: 480px;
  --desktop-max-width: 1440px;
  --sidebar-width: 260px;

  /* ── Visualizer ────────────────────────── */
  --viz-bar-count: 32;
  --viz-color-start: #FFFFFF;
  --viz-color-end: #808080;
}

/* ── Dark Theme (default) ────────────── */
[data-theme="dark"] {
  color-scheme: dark;
}

/* ── Light Theme Override — white & black ── */
[data-theme="light"] {
  color-scheme: light;

  --bg-deepest: #FFFFFF;
  --bg-deep: #FAFAFA;
  --bg-primary: #F5F5F5;
  --bg-secondary: #FFFFFF;
  --bg-elevated: #FFFFFF;
  --bg-surface: #F3F3F3;
  --bg-hover: #EAEAEA;

  --accent-purple: #000000;
  --accent-blue: #1A1A1A;
  --accent-cyan: #262626;
  --accent-gradient: linear-gradient(135deg, #000000 0%, #2E2E2E 100%);
  --accent-gradient-vibrant: linear-gradient(135deg, #000000 0%, #333333 100%);
  --accent-gradient-warm: linear-gradient(135deg, #000000 0%, #3D3D3D 100%);
  --accent-gradient-horizontal: linear-gradient(90deg, #000000 0%, #333333 100%);

  --neon-purple: #000000;
  --neon-blue: #1A1A1A;
  --neon-pink: #262626;
  --neon-cyan: #333333;
  --glow-purple: rgba(0, 0, 0, 0.10);
  --glow-blue: rgba(0, 0, 0, 0.08);
  --glow-pink: rgba(0, 0, 0, 0.08);

  --text-primary: #111111;
  --text-secondary: #6B6B6B;
  --text-tertiary: #9B9B9B;
  --text-muted: #C7C7C7;
  --text-accent: #000000;

  --border-subtle: rgba(0, 0, 0, 0.07);
  --border-default: rgba(0, 0, 0, 0.12);
  --border-accent: rgba(0, 0, 0, 0.35);

  --glass-bg: rgba(255, 255, 255, 0.72);
  --glass-bg-light: rgba(255, 255, 255, 0.55);
  --glass-bg-heavy: rgba(255, 255, 255, 0.88);
  --glass-border: 1px solid rgba(0, 0, 0, 0.06);
  --glass-border-accent: 1px solid rgba(0, 0, 0, 0.12);

  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.07);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.09);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.12);
  --shadow-glow-purple: 0 0 20px rgba(0, 0, 0, 0.08);
  --shadow-glow-blue: 0 0 20px rgba(0, 0, 0, 0.06);
  --shadow-glow-accent: 0 4px 20px rgba(0, 0, 0, 0.08);
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.05), 0 0 1px rgba(0, 0, 0, 0.08);

  --viz-color-start: #000000;
  --viz-color-end: #B0B0B0;
}

/* ── Reduced Motion ──────────────────── */
@media (prefers-reduced-motion: reduce) {
  :root {
    --duration-fast: 0ms;
    --duration-normal: 0ms;
    --duration-medium: 0ms;
    --duration-slow: 0ms;
    --duration-slower: 0ms;
    --duration-slowest: 0ms;
  }
}


/* ============================================
   NEVER — Base Styles & Reset
   ============================================ */

/* ── CSS Reset ───────────────────────────── */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
  overflow: hidden;
  height: 100%;
  height: -webkit-fill-available;
}

body {
  font-family: var(--font-primary);
  background-color: var(--bg-deepest);
  color: var(--text-primary);
  line-height: var(--leading-normal);
  overflow: hidden;
  height: 100%;
  height: -webkit-fill-available;
  position: fixed;
  width: 100%;
  user-select: none;
  -webkit-user-select: none;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  border: none;
  background: none;
  font: inherit;
  color: inherit;
  cursor: pointer;
  outline: none;
}

input, textarea {
  border: none;
  background: none;
  font: inherit;
  color: inherit;
  outline: none;
}

ul, ol {
  list-style: none;
}

img, video {
  display: block;
  max-width: 100%;
}

/* ── Scrollbar Styles ────────────────────── */
::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--text-muted);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-tertiary);
}

/* Hide scrollbar for horizontal scroll containers */
.scroll-hide::-webkit-scrollbar {
  display: none;
}
.scroll-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* ── App Container ───────────────────────── */
#app {
  position: relative;
  width: 100%;
  height: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  overflow: hidden;
  background: var(--bg-deep);
}

/* Desktop layout */
@media (min-width: 1024px) {
  #app {
    /* Was centered with max-width + margin:0 auto (inherited from the
       base rule above), which left empty space on both sides on wide
       monitors and pushed the sidebar away from the real corner.
       Removing the cap so the sidebar sits flush at the true edge. */
    max-width: none;
    margin: 0;
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    grid-template-rows: 1fr auto auto;
  }
}

/* ── Typography Utilities ────────────────── */
.text-xs { font-size: var(--text-xs); }
.text-sm { font-size: var(--text-sm); }
.text-base { font-size: var(--text-base); }
.text-md { font-size: var(--text-md); }
.text-lg { font-size: var(--text-lg); }
.text-xl { font-size: var(--text-xl); }
.text-2xl { font-size: var(--text-2xl); }
.text-3xl { font-size: var(--text-3xl); }

.font-light { font-weight: var(--weight-light); }
.font-normal { font-weight: var(--weight-normal); }
.font-medium { font-weight: var(--weight-medium); }
.font-semibold { font-weight: var(--weight-semibold); }
.font-bold { font-weight: var(--weight-bold); }
.font-extrabold { font-weight: var(--weight-extrabold); }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-muted { color: var(--text-muted); }
.text-accent { color: var(--text-accent); }

.text-gradient {
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Glassmorphism Utilities ─────────────── */
.glass {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: var(--glass-border);
}

.glass-light {
  background: var(--glass-bg-light);
  backdrop-filter: var(--glass-blur-light);
  -webkit-backdrop-filter: var(--glass-blur-light);
  border: var(--glass-border);
}

.glass-heavy {
  background: var(--glass-bg-heavy);
  backdrop-filter: var(--glass-blur-heavy);
  -webkit-backdrop-filter: var(--glass-blur-heavy);
  border: var(--glass-border);
}

/* ── Layout Utilities ────────────────────── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }
.gap-5 { gap: var(--space-5); }
.gap-6 { gap: var(--space-6); }
.gap-8 { gap: var(--space-8); }

.grid { display: grid; }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-3 { grid-template-columns: repeat(3, 1fr); }

.w-full { width: 100%; }
.h-full { height: 100%; }
.relative { position: relative; }
.absolute { position: absolute; }
.overflow-hidden { overflow: hidden; }

/* ── Padding Utilities ───────────────────── */
.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }
.p-5 { padding: var(--space-5); }
.p-6 { padding: var(--space-6); }
.px-4 { padding-left: var(--space-4); padding-right: var(--space-4); }
.px-5 { padding-left: var(--space-5); padding-right: var(--space-5); }
.px-6 { padding-left: var(--space-6); padding-right: var(--space-6); }
.py-3 { padding-top: var(--space-3); padding-bottom: var(--space-3); }
.py-4 { padding-top: var(--space-4); padding-bottom: var(--space-4); }

/* ── Horizontal Scroll Container ─────────── */
.h-scroll {
  display: flex;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: var(--space-2);
}

.h-scroll > * {
  scroll-snap-align: start;
  flex-shrink: 0;
}

/* ── Section Titles ──────────────────────── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  padding-bottom: var(--space-3);
}

.section-title {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  letter-spacing: var(--tracking-tight);
  color: var(--text-primary);
}

.section-action {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--text-accent);
  cursor: pointer;
  transition: opacity var(--duration-fast) var(--ease-smooth);
}

.section-action:hover {
  opacity: 0.8;
}

/* ── Ambient Background Effects ──────────── */
.ambient-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.ambient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  opacity: 0.05;
  animation: ambientFloat 24s ease-in-out infinite;
}

.ambient-orb-1 {
  width: 300px;
  height: 300px;
  background: var(--accent-purple);
  top: -100px;
  right: -100px;
  animation-delay: 0s;
}

.ambient-orb-2 {
  width: 250px;
  height: 250px;
  background: var(--accent-blue);
  bottom: 20%;
  left: -80px;
  animation-delay: -7s;
}

.ambient-orb-3 {
  width: 200px;
  height: 200px;
  background: var(--neon-pink);
  top: 40%;
  right: -60px;
  animation-delay: -14s;
  opacity: 0.03;
}

@keyframes ambientFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(30px, -20px) scale(1.1); }
  50% { transform: translate(-20px, 30px) scale(0.95); }
  75% { transform: translate(20px, 20px) scale(1.05); }
}

/* ── Selection ───────────────────────────── */
::selection {
  background: rgba(139, 92, 246, 0.3);
  color: var(--text-primary);
}


/* ============================================
   NEVER — Animations & Keyframes
   ============================================ */

/* ── Page Transitions ────────────────────── */
.screen.active {
  animation: screenFadeIn var(--duration-medium) var(--ease-smooth) forwards;
}

.screen-enter {
  animation: screenSlideIn var(--duration-slow) var(--ease-spring-soft) forwards;
}

.screen-exit {
  animation: screenSlideOut var(--duration-normal) var(--ease-smooth) forwards;
}

@keyframes screenFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes screenSlideIn {
  from { opacity: 0; transform: translateX(30px) scale(0.98); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

@keyframes screenSlideOut {
  from { opacity: 1; transform: translateX(0) scale(1); }
  to { opacity: 0; transform: translateX(-30px) scale(0.98); }
}

/* ── Tab Switch Animation ────────────────── */
@keyframes tabPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.25); }
  100% { transform: scale(1.15); }
}

@keyframes tabGlow {
  0% { box-shadow: 0 0 0 rgba(139, 92, 246, 0); }
  50% { box-shadow: 0 0 20px rgba(139, 92, 246, 0.4); }
  100% { box-shadow: 0 0 12px rgba(139, 92, 246, 0.2); }
}

/* ── Card Animations ─────────────────────── */
@keyframes cardAppear {
  from {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes cardHover {
  from { transform: translateY(0); }
  to { transform: translateY(-4px); }
}

.card-stagger {
  opacity: 0;
  animation: cardAppear var(--duration-slow) var(--ease-spring-soft) forwards;
}

.card-stagger:nth-child(1) { animation-delay: 0ms; }
.card-stagger:nth-child(2) { animation-delay: 60ms; }
.card-stagger:nth-child(3) { animation-delay: 120ms; }
.card-stagger:nth-child(4) { animation-delay: 180ms; }
.card-stagger:nth-child(5) { animation-delay: 240ms; }
.card-stagger:nth-child(6) { animation-delay: 300ms; }
.card-stagger:nth-child(7) { animation-delay: 360ms; }
.card-stagger:nth-child(8) { animation-delay: 420ms; }

/* ── Glow Pulse ──────────────────────────── */
@keyframes glowPulse {
  0%, 100% {
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.2);
  }
  50% {
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.4), 0 0 60px rgba(139, 92, 246, 0.1);
  }
}

@keyframes glowPulseBlue {
  0%, 100% {
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
  }
  50% {
    box-shadow: 0 0 30px rgba(59, 130, 246, 0.4), 0 0 60px rgba(59, 130, 246, 0.1);
  }
}

/* ── Floating / Levitation ───────────────── */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@keyframes floatSlow {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  33% { transform: translateY(-8px) rotate(1deg); }
  66% { transform: translateY(4px) rotate(-1deg); }
}

/* ── Vinyl Spin ──────────────────────────── */
@keyframes vinylSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.vinyl-spinning {
  animation: vinylSpin 3s linear infinite;
}

.vinyl-paused {
  animation-play-state: paused;
}

/* ── Visualizer Bars ─────────────────────── */
@keyframes vizBar {
  0%, 100% { transform: scaleY(0.15); }
  50% { transform: scaleY(1); }
}

.viz-bar {
  animation: vizBar 1.2s ease-in-out infinite;
}

.viz-bar:nth-child(1) { animation-duration: 0.8s; animation-delay: 0s; }
.viz-bar:nth-child(2) { animation-duration: 1.1s; animation-delay: 0.1s; }
.viz-bar:nth-child(3) { animation-duration: 0.9s; animation-delay: 0.2s; }
.viz-bar:nth-child(4) { animation-duration: 1.3s; animation-delay: 0.15s; }
.viz-bar:nth-child(5) { animation-duration: 1.0s; animation-delay: 0.25s; }
.viz-bar:nth-child(6) { animation-duration: 1.2s; animation-delay: 0.05s; }
.viz-bar:nth-child(7) { animation-duration: 0.85s; animation-delay: 0.3s; }
.viz-bar:nth-child(8) { animation-duration: 1.15s; animation-delay: 0.12s; }

/* ── Wave Animation ──────────────────────── */
@keyframes wave {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.wave-animate {
  animation: wave 8s linear infinite;
}

/* ── Progress Shimmer ────────────────────── */
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(200%); }
}

.shimmer::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  animation: shimmer 2s ease-in-out infinite;
}

/* ── Scale Bounce (for buttons, likes) ───── */
@keyframes scaleBounce {
  0% { transform: scale(1); }
  30% { transform: scale(0.85); }
  60% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  15% { transform: scale(1.3); }
  30% { transform: scale(1); }
  45% { transform: scale(1.2); }
  60% { transform: scale(1); }
}

.scale-bounce {
  animation: scaleBounce var(--duration-medium) var(--ease-spring) forwards;
}

.heart-beat {
  animation: heartBeat 0.6s var(--ease-spring) forwards;
}

/* ── Ripple Effect ───────────────────────── */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 0.5;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

.ripple-effect {
  position: relative;
  overflow: hidden;
}

.ripple-effect .ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0);
  animation: ripple 0.6s var(--ease-smooth);
  pointer-events: none;
}

/* ── Fade Animations ─────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-16px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.fade-in { animation: fadeIn var(--duration-medium) var(--ease-smooth) forwards; }
.fade-in-up { animation: fadeInUp var(--duration-slow) var(--ease-spring-soft) forwards; }
.fade-in-down { animation: fadeInDown var(--duration-slow) var(--ease-spring-soft) forwards; }
.fade-in-scale { animation: fadeInScale var(--duration-slow) var(--ease-spring-soft) forwards; }

/* ── Player Slide ────────────────────────── */
@keyframes playerSlideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes playerSlideDown {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(100%);
    opacity: 0;
  }
}

/* ── Lyrics Animation ────────────────────── */
@keyframes lyricHighlight {
  from {
    opacity: 0.4;
    transform: scale(0.97);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes lyricGlow {
  0%, 100% { text-shadow: 0 0 10px rgba(139, 92, 246, 0.3); }
  50% { text-shadow: 0 0 20px rgba(139, 92, 246, 0.6); }
}

/* ── Skeleton Loading ────────────────────── */
@keyframes skeletonPulse {
  0%, 100% { opacity: 0.05; }
  50% { opacity: 0.12; }
}

.skeleton {
  background: var(--bg-elevated);
  border-radius: var(--radius-md);
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

/* ── Number Counter ──────────────────────── */
@keyframes countUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Gradient Rotation ───────────────────── */
@keyframes gradientRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ── Equalizer Bars ──────────────────────── */
@keyframes eqBar1 {
  0%, 100% { height: 12px; }
  25% { height: 28px; }
  50% { height: 8px; }
  75% { height: 22px; }
}
@keyframes eqBar2 {
  0%, 100% { height: 20px; }
  25% { height: 8px; }
  50% { height: 28px; }
  75% { height: 14px; }
}
@keyframes eqBar3 {
  0%, 100% { height: 16px; }
  30% { height: 28px; }
  60% { height: 10px; }
  80% { height: 24px; }
}

/* ── Notification Badge ──────────────────── */
@keyframes badgePing {
  75%, 100% {
    transform: scale(2);
    opacity: 0;
  }
}

/* ── Interactive Feedback ────────────────── */
.pressable {
  transition: transform var(--duration-fast) var(--ease-smooth);
  cursor: pointer;
}

.pressable:active {
  transform: scale(0.96);
}

.hoverable {
  transition: all var(--duration-normal) var(--ease-smooth);
}

.hoverable:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* ── Music Note Float ────────────────────── */
@keyframes noteFloat {
  0% {
    opacity: 1;
    transform: translateY(0) rotate(0deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-60px) rotate(20deg) scale(0.5);
  }
}

/* ── Slide In from sides ─────────────────── */
@keyframes slideInRight {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes slideInLeft {
  from { transform: translateX(-100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes slideInBottom {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* ── Progress Ring ───────────────────────── */
@keyframes progressRing {
  from { stroke-dashoffset: 283; }
}

/* ── Breathing / Pulsating ───────────────── */
@keyframes breathe {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* ── Particle Drift ──────────────────────── */
@keyframes particleDrift {
  0% {
    transform: translate(0, 0) rotate(0deg);
    opacity: 0;
  }
  10% { opacity: 0.8; }
  90% { opacity: 0.8; }
  100% {
    transform: translate(var(--drift-x, 50px), var(--drift-y, -80px)) rotate(var(--drift-r, 180deg));
    opacity: 0;
  }
}


/* ============================================
   NEVER — UI Components
   ============================================ */

/* ── Bottom Navigation Bar / Sidebar ─────── */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: var(--content-max-width);
  height: var(--nav-height);
  padding-bottom: var(--bottom-safe);
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--glass-bg-heavy);
  backdrop-filter: blur(30px) saturate(180%);
  -webkit-backdrop-filter: blur(30px) saturate(180%);
  border-top: 1px solid var(--border-subtle);
  z-index: var(--z-nav);
  transition: transform var(--duration-medium) var(--ease-smooth);
}

.bottom-nav.hidden {
  transform: translateX(-50%) translateY(100%);
}

.nav-logo {
  display: none; /* shown only in the desktop sidebar */
}

.nav-items {
  display: contents;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: var(--radius-lg);
  transition: all var(--duration-medium) var(--ease-spring);
  cursor: pointer;
}

.nav-item svg {
  width: 24px;
  height: 24px;
  stroke: var(--text-tertiary);
  stroke-width: 1.8;
  fill: none;
  transition: all var(--duration-medium) var(--ease-spring);
  flex-shrink: 0;
}

.nav-item.active {
  transform: scale(1.1);
}

.nav-item.active svg {
  stroke: var(--text-primary);
  stroke-width: 2;
}

.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: var(--text-primary);
  border-radius: 50%;
}

.nav-item:not(.active):hover svg {
  stroke: var(--text-secondary);
}

.nav-item-label {
  display: none; /* shown only in the desktop sidebar */
}

/* ── Mini Player ─────────────────────────── */
.mini-player {
  position: fixed;
  bottom: var(--nav-height);
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 16px);
  max-width: calc(var(--content-max-width) - 16px);
  height: var(--mini-player-height);
  background: var(--glass-bg-heavy);
  backdrop-filter: blur(30px) saturate(180%);
  -webkit-backdrop-filter: blur(30px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  padding: 0 var(--space-3);
  gap: var(--space-3);
  z-index: var(--z-mini-player);
  cursor: pointer;
  transition: all var(--duration-medium) var(--ease-smooth);
  overflow: hidden;
  margin-bottom: 4px;
}

.mini-player::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  height: 2px;
  width: var(--progress, 35%);
  background: var(--accent-gradient-horizontal);
  border-radius: 0 1px 0 0;
  transition: width 1s linear;
}

.mini-player:active {
  transform: translateX(-50%) scale(0.98);
}

.mini-player-cover {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}

.mini-player-cover img,
.mini-player-cover .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mini-player-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.mini-player-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-player-artist {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-player-controls {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  flex-shrink: 0;
}

.mini-player-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.mini-player-btn:active {
  transform: scale(0.9);
}

.mini-player-btn svg {
  width: 22px;
  height: 22px;
  fill: var(--text-primary);
}

.mini-player-btn.play-btn svg {
  width: 24px;
  height: 24px;
}

/* ── Equalizer Mini ──────────────────────── */
.eq-mini {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 16px;
  width: 13px;
  margin-left: var(--space-1);
  flex-shrink: 0;
  opacity: 1;
  transition: opacity var(--duration-normal) var(--ease-smooth);
}

.eq-mini.paused {
  opacity: 0;
}

.eq-mini.paused .eq-mini-bar {
  animation-play-state: paused;
}

.eq-mini-bar {
  width: 3px;
  border-radius: 2px;
  background: var(--accent-gradient);
}

.eq-mini-bar:nth-child(1) { animation: eqBar1 0.8s ease-in-out infinite; }
.eq-mini-bar:nth-child(2) { animation: eqBar2 0.9s ease-in-out infinite; }
.eq-mini-bar:nth-child(3) { animation: eqBar3 0.7s ease-in-out infinite; }

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  background: var(--bg-surface);
}

/* ── Music Cards ─────────────────────────── */
.card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  transition: all var(--duration-medium) var(--ease-smooth);
  cursor: pointer;
}

.card:hover {
  border-color: var(--border-default);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.card:active {
  transform: translateY(0) scale(0.98);
}

/* Track Card (horizontal) */
.track-card {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3);
  border-radius: var(--radius-md);
  background: transparent;
  border: none;
  transition: background var(--duration-fast) var(--ease-smooth);
}

.track-card:hover {
  background: rgba(255, 255, 255, 0.04);
  transform: none;
  box-shadow: none;
}

.track-card:active {
  background: rgba(255, 255, 255, 0.06);
  transform: scale(0.99);
}

.track-card.playing {
  background: rgba(139, 92, 246, 0.08);
}

.track-card.playing .track-title {
  color: var(--accent-purple);
}

.track-cover {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}

.track-cover img,
.track-cover .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.track-cover .play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  transition: opacity var(--duration-fast) var(--ease-smooth);
}

.track-card:hover .play-overlay {
  opacity: 1;
}

.track-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.track-title {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-artist {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-duration {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  font-family: var(--font-mono);
  flex-shrink: 0;
}

.track-actions {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  flex-shrink: 0;
}

.track-number {
  width: 24px;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--text-tertiary);
  text-align: center;
  flex-shrink: 0;
}

/* Album / Playlist Card (vertical) */
.album-card {
  width: 160px;
  padding: var(--space-3);
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-subtle);
  flex-shrink: 0;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.album-card:hover {
  transform: translateY(-4px);
  border-color: var(--border-default);
  box-shadow: var(--shadow-glow-purple);
}

.album-card:active {
  transform: translateY(-2px) scale(0.98);
}

.album-card-cover {
  width: 100%;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-3);
  position: relative;
}

.album-card-cover img,
.album-card-cover .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.album-card-cover .play-fab {
  position: absolute;
  bottom: 8px;
  right: 8px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(8px);
  transition: all var(--duration-normal) var(--ease-spring);
  box-shadow: var(--shadow-glow-accent);
}

.album-card:hover .play-fab {
  opacity: 1;
  transform: translateY(0);
}

.play-fab svg {
  width: 16px;
  height: 16px;
  fill: white;
  margin-left: 2px;
}

.album-card-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.album-card-subtitle {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Continue Listening Card (Wide) ──────── */
.continue-card {
  width: 200px;
  height: 64px;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0;
  padding-right: var(--space-3);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  border: 1px solid var(--border-subtle);
  overflow: hidden;
  flex-shrink: 0;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.continue-card:hover {
  background: var(--bg-elevated);
  border-color: var(--border-default);
}

.continue-card:active {
  transform: scale(0.98);
}

.continue-card-cover {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
}

.continue-card-cover img,
.continue-card-cover .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.continue-card-info {
  flex: 1;
  min-width: 0;
}

.continue-card-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}

.continue-card-artist {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
}

/* ── Artist Circle Card ──────────────────── */
.artist-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  width: 90px;
  flex-shrink: 0;
  cursor: pointer;
}

.artist-circle-img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid var(--border-subtle);
  transition: all var(--duration-medium) var(--ease-smooth);
}

.artist-circle:hover .artist-circle-img {
  border-color: var(--accent-purple);
  box-shadow: var(--shadow-glow-purple);
  transform: scale(1.05);
}

.artist-circle-img img,
.artist-circle-img .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.artist-circle-name {
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

/* ── Mood Card ───────────────────────────── */
.mood-card {
  width: 140px;
  height: 80px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: flex-end;
  padding: var(--space-3);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.mood-card:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: var(--shadow-lg);
}

.mood-card:active {
  transform: scale(0.97);
}

.mood-card-label {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: white;
  position: relative;
  z-index: 2;
  text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.mood-card-icon {
  position: absolute;
  top: 10px;
  right: 12px;
  font-size: 28px;
  opacity: 0.7;
  z-index: 2;
}

/* ── Icon Button ─────────────────────────── */
.icon-btn {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  transition: all var(--duration-fast) var(--ease-smooth);
  cursor: pointer;
  flex-shrink: 0;
}

.icon-btn:hover {
  background: rgba(255, 255, 255, 0.08);
}

.icon-btn:active {
  transform: scale(0.9);
}

.icon-btn svg {
  width: 22px;
  height: 22px;
  stroke: var(--text-secondary);
  stroke-width: 1.8;
  fill: none;
}

.icon-btn.active svg {
  stroke: var(--accent-purple);
  fill: var(--accent-purple);
}

.icon-btn.liked svg {
  stroke: #EF4444;
  fill: #EF4444;
}

/* ── Primary Button ──────────────────────── */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  background: var(--accent-gradient);
  border-radius: var(--radius-full);
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: white;
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-smooth);
  box-shadow: var(--shadow-glow-accent);
  position: relative;
  overflow: hidden;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 30px rgba(139, 92, 246, 0.4);
}

.btn-primary:active {
  transform: translateY(0) scale(0.97);
}

/* ── Ghost Button ────────────────────────── */
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-smooth);
}

.btn-ghost:hover {
  background: rgba(255, 255, 255, 0.10);
  color: var(--text-primary);
  border-color: rgba(255, 255, 255, 0.15);
}

.btn-ghost.active {
  background: rgba(139, 92, 246, 0.15);
  border-color: var(--accent-purple);
  color: var(--accent-purple);
}

/* ── Tag / Chip ──────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-1) var(--space-3);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
  color: var(--text-secondary);
  white-space: nowrap;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.tag:hover {
  background: rgba(255, 255, 255, 0.10);
  border-color: var(--border-default);
}

.tag.active {
  background: rgba(139, 92, 246, 0.15);
  border-color: rgba(139, 92, 246, 0.3);
  color: var(--accent-purple);
}

/* ── Search Input ────────────────────────── */
.search-bar {
  position: relative;
  width: 100%;
}

.search-bar input {
  width: 100%;
  height: 44px;
  padding: 0 var(--space-4) 0 44px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  font-size: var(--text-base);
  color: var(--text-primary);
  transition: all var(--duration-normal) var(--ease-smooth);
}

.search-bar input::placeholder {
  color: var(--text-muted);
}

.search-bar input:focus {
  background: var(--bg-surface);
  border-color: var(--accent-purple);
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

.search-bar .search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  width: 18px;
  height: 18px;
  stroke: var(--text-muted);
  stroke-width: 2;
  fill: none;
  pointer-events: none;
}

/* ── Toggle Switch ───────────────────────── */
.toggle {
  position: relative;
  width: 48px;
  height: 28px;
  background: var(--bg-surface);
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: background var(--duration-normal) var(--ease-smooth);
  flex-shrink: 0;
}

.toggle.active {
  background: var(--accent-purple);
}

.toggle::after {
  content: '';
  position: absolute;
  top: 3px;
  left: 3px;
  width: 22px;
  height: 22px;
  background: white;
  border-radius: 50%;
  transition: transform var(--duration-normal) var(--ease-spring);
  box-shadow: var(--shadow-sm);
}

.toggle.active::after {
  transform: translateX(20px);
}

/* ── Avatar ──────────────────────────────── */
.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid var(--border-subtle);
  flex-shrink: 0;
}

.avatar-lg {
  width: 80px;
  height: 80px;
}

.avatar-xl {
  width: 120px;
  height: 120px;
  border-width: 3px;
}

.avatar img,
.avatar .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ── Divider ─────────────────────────────── */
.divider {
  height: 1px;
  background: var(--border-subtle);
  margin: var(--space-2) 0;
}

/* ── Setting Row ─────────────────────────── */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-smooth);
}

.setting-row:hover {
  background: rgba(255, 255, 255, 0.03);
}

.setting-row:active {
  background: rgba(255, 255, 255, 0.05);
}

.setting-row-left {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex: 1;
  min-width: 0;
}

.setting-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--bg-elevated);
}

.setting-icon svg {
  width: 20px;
  height: 20px;
  stroke: var(--text-secondary);
  stroke-width: 1.8;
  fill: none;
}

.setting-label {
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
}

.setting-sublabel {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

.setting-row-right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.setting-value {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

.chevron-right {
  width: 16px;
  height: 16px;
  stroke: var(--text-muted);
  stroke-width: 2;
  fill: none;
}

/* ── Wave Card (Твоя Волна) ──────────────── */
.wave-card {
  position: relative;
  width: calc(100% - 40px);
  margin: 0 auto;
  height: 160px;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  cursor: pointer;
  background: linear-gradient(135deg, #1a0533 0%, #0f1a3e 50%, #0a2540 100%);
}

.wave-card-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-6);
}

.wave-card-label {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  text-transform: uppercase;
  letter-spacing: var(--tracking-widest);
  color: var(--neon-purple);
  margin-bottom: var(--space-2);
}

.wave-card-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-extrabold);
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.wave-card-subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.wave-card-visual {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 60%;
  height: 100%;
  z-index: 1;
}

.wave-card-btn {
  position: absolute;
  bottom: var(--space-5);
  right: var(--space-5);
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  box-shadow: var(--shadow-glow-accent);
  transition: all var(--duration-normal) var(--ease-spring);
}

.wave-card-btn:hover {
  transform: scale(1.1);
}

.wave-card-btn svg {
  width: 22px;
  height: 22px;
  fill: white;
  margin-left: 2px;
}

/* ── Stat Card (Музыкальный паспорт) ────── */
.stat-card {
  padding: var(--space-5);
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  text-align: center;
}

.stat-number {
  font-size: var(--text-3xl);
  font-weight: var(--weight-black);
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-family: var(--font-mono);
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-1);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
}

/* ── Cover Gradient Placeholders ─────────── */
.cover-gradient {
  width: 100%;
  height: 100%;
  border-radius: inherit;
}

.cover-1 { background: url('../assets/cover-1.png') center/cover no-repeat, linear-gradient(135deg, #1a0533 0%, #3B0764 40%, #581C87 70%, #6D28D9 100%); }
.cover-2 { background: url('../assets/cover-2.png') center/cover no-repeat, linear-gradient(135deg, #0C4A6E 0%, #0369A1 40%, #0EA5E9 100%); }
.cover-3 { background: url('../assets/cover-3.png') center/cover no-repeat, linear-gradient(135deg, #4C1D95 0%, #6D28D9 30%, #7C3AED 60%, #A78BFA 100%); }
.cover-4 { background: url('../assets/cover-4.png') center/cover no-repeat, linear-gradient(135deg, #0F172A 0%, #1E293B 40%, #334155 100%); }
.cover-5 { background: url('../assets/cover-5.png') center/cover no-repeat, linear-gradient(135deg, #831843 0%, #BE185D 40%, #EC4899 100%); }
.cover-6 { background: url('../assets/cover-6.png') center/cover no-repeat, linear-gradient(135deg, #064E3B 0%, #059669 40%, #10B981 100%); }
.cover-7 { background: linear-gradient(225deg, #1E1B4B 0%, #3730A3 40%, #4F46E5 80%, #818CF8 100%); }
.cover-8 { background: linear-gradient(135deg, #78350F 0%, #D97706 40%, #FBBF24 100%); }
.cover-9 { background: linear-gradient(135deg, #7F1D1D 0%, #DC2626 40%, #F87171 100%); }
.cover-10 { background: linear-gradient(135deg, #134E4A 0%, #0D9488 40%, #2DD4BF 100%); }
.cover-11 { background: linear-gradient(135deg, #1E1B4B 0%, #4338CA 40%, #6366F1 60%, #A5B4FC 100%); }
.cover-12 { background: linear-gradient(145deg, #0a0014 0%, #2D1B69 30%, #5B21B6 60%, #8B5CF6 90%, #C4B5FD 100%); }

/* Artist gradients (circular) */
.artist-1 { background: radial-gradient(circle at 30% 30%, #8B5CF6, #4C1D95); }
.artist-2 { background: radial-gradient(circle at 40% 40%, #EC4899, #831843); }
.artist-3 { background: radial-gradient(circle at 30% 30%, #3B82F6, #1E3A8A); }
.artist-4 { background: radial-gradient(circle at 40% 30%, #10B981, #064E3B); }
.artist-5 { background: radial-gradient(circle at 30% 40%, #F59E0B, #78350F); }
.artist-6 { background: radial-gradient(circle at 40% 30%, #EF4444, #7F1D1D); }

/* ── Toast / Notification ────────────────── */
.toast {
  position: fixed;
  top: calc(var(--status-bar-height) + 16px);
  left: 50%;
  transform: translateX(-50%) translateY(-100px);
  padding: var(--space-3) var(--space-5);
  background: var(--glass-bg-heavy);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: var(--glass-border);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
  z-index: var(--z-toast);
  transition: transform var(--duration-slow) var(--ease-spring);
  box-shadow: var(--shadow-lg);
}

.toast.show {
  transform: translateX(-50%) translateY(0);
}

/* ── Library Category Card ───────────────── */
.lib-category {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-5);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-smooth);
  border-radius: var(--radius-md);
}

.lib-category:hover {
  background: rgba(255, 255, 255, 0.04);
}

.lib-category:active {
  background: rgba(255, 255, 255, 0.06);
}

.lib-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.lib-icon svg {
  width: 24px;
  height: 24px;
  stroke: white;
  stroke-width: 1.8;
  fill: none;
}

.lib-label {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.lib-count {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* ── Badge ───────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  background: var(--accent-gradient);
  border-radius: var(--radius-full);
  font-size: 10px;
  font-weight: var(--weight-bold);
  color: white;
}

/* ── Progress Bar ────────────────────────── */
.progress-bar {
  width: 100%;
  height: 3px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-full);
  overflow: hidden;
  position: relative;
}

.progress-bar-fill {
  height: 100%;
  background: var(--accent-gradient-horizontal);
  border-radius: var(--radius-full);
  transition: width 0.3s linear;
  position: relative;
}

/* ── No-Glass Override (Solid backgrounds) ── */
html.no-glass {
  --glass-bg: #14141F !important;
  --glass-bg-light: #1A1A2E !important;
  --glass-bg-heavy: #0A0A12 !important;
  --glass-blur: none !important;
  --glass-blur-light: none !important;
  --glass-blur-heavy: none !important;
  --glass-border: 1px solid rgba(255, 255, 255, 0.15) !important;
}

html.no-glass[data-theme="light"] {
  --glass-bg: #EAEBF2 !important;
  --glass-bg-light: #FFFFFF !important;
  --glass-bg-heavy: #FFFFFF !important;
  --glass-border: 1px solid rgba(0, 0, 0, 0.15) !important;
}

/* Force removal of backdrop-filters */
html.no-glass .bottom-nav,
html.no-glass .mini-player,
html.no-glass .player-fullscreen,
html.no-glass .toast,
html.no-glass .lyrics-overlay,
html.no-glass .detail-modal,
html.no-glass .time-card,
html.no-glass .mood-card,
html.no-glass .sub-card,
html.no-glass .concert-card,
html.no-glass .passport-card {
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}

/* ── Generic Detail Modal ─────────────────────
   Opens for album/playlist cards, library categories
   (Альбомы, Плейлисты, Исполнители...) and settings rows.
   ───────────────────────────────────────────── */
.detail-modal {
  position: fixed;
  inset: 0;
  z-index: var(--z-toast);
  background: var(--glass-bg-heavy);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-medium) var(--ease-smooth);
}

.detail-modal.open {
  opacity: 1;
  pointer-events: auto;
}

.detail-modal-card {
  position: relative;
  width: 100%;
  max-width: var(--content-max-width);
  max-height: 80vh;
  overflow-y: auto;
  background: var(--bg-elevated);
  border: var(--glass-border);
  border-bottom: none;
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding: var(--space-6) var(--space-5) var(--space-10);
  transform: translateY(24px);
  transition: transform var(--duration-medium) var(--ease-spring-soft);
}

.detail-modal.open .detail-modal-card {
  transform: translateY(0);
}

.detail-modal-close {
  position: absolute;
  top: var(--space-4);
  right: var(--space-4);
  background: var(--bg-hover);
}

.detail-list-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-2) var(--space-1);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-smooth);
}

.detail-list-item:hover {
  background: var(--bg-hover);
}

@media (min-width: 1024px) {
  .detail-modal {
    align-items: center;
  }
  .detail-modal-card {
    border-radius: var(--radius-2xl);
    border-bottom: var(--glass-border);
    max-height: 70vh;
  }
}

/* ── No-Animations Override ────────────────── */
html.no-animations *, 
html.no-animations *::before, 
html.no-animations *::after {
  animation-duration: 0s !important;
  animation-delay: 0s !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0s !important;
  transition-delay: 0s !important;
}


/* ══════════════════════════════════════════
   AUTH SCREEN (login / register / social)
   ══════════════════════════════════════════ */
.auth-screen {
  position: fixed;
  inset: 0;
  z-index: var(--z-max);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-deepest);
  overflow-y: auto;
  padding: var(--space-6);
  transition: opacity var(--duration-medium) var(--ease-smooth), visibility var(--duration-medium);
}

.auth-screen.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.auth-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 400px;
  background: var(--glass-bg-heavy);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: var(--glass-border);
  border-radius: var(--radius-2xl);
  padding: var(--space-8) var(--space-6);
  box-shadow: var(--shadow-xl);
  margin: auto;
}

.auth-logo {
  font-size: var(--text-3xl);
  font-weight: var(--weight-extrabold);
  letter-spacing: var(--tracking-wider);
  text-align: center;
}

.auth-tagline {
  text-align: center;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  margin-top: var(--space-1);
  margin-bottom: var(--space-6);
}

.auth-tabs {
  display: flex;
  background: var(--bg-surface);
  border-radius: var(--radius-full);
  padding: 4px;
  margin-bottom: var(--space-6);
}

.auth-tab {
  flex: 1;
  padding: var(--space-2) 0;
  text-align: center;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.auth-tab.active {
  background: var(--accent-gradient);
  color: #fff;
}

.auth-social {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

.auth-social-btn {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  width: 100%;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  color: var(--text-primary);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.auth-social-btn:hover {
  background: var(--bg-hover);
  transform: translateY(-1px);
}

.auth-social-btn:active {
  transform: scale(0.98);
}

.auth-social-icon {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-weight: var(--weight-bold);
  font-size: var(--text-sm);
}

.auth-social-icon svg {
  width: 100%;
  height: 100%;
}

.auth-social-icon-google { background: #fff; padding: 3px; }
.auth-social-icon-apple { color: #fff; }
.auth-social-icon-discord { color: #5865F2; }
.auth-social-icon-telegram { color: #29B6F6; }

.auth-divider {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  color: var(--text-tertiary);
  font-size: var(--text-xs);
  margin-bottom: var(--space-5);
}

.auth-divider::before,
.auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border-default);
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.auth-field {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.auth-field label {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
}

.auth-field input {
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  color: var(--text-primary);
  font-size: var(--text-base);
  transition: border-color var(--duration-fast) var(--ease-smooth);
}

.auth-field input:focus {
  border-color: var(--accent-purple);
}

.auth-error {
  color: var(--color-error);
  font-size: var(--text-sm);
  min-height: 0;
  display: none;
}

.auth-error.visible {
  display: block;
}

.auth-submit {
  padding: var(--space-3) 0;
  border-radius: var(--radius-full);
  background: var(--accent-gradient);
  color: #fff;
  font-weight: var(--weight-semibold);
  font-size: var(--text-base);
  cursor: pointer;
  transition: transform var(--duration-fast) var(--ease-smooth), opacity var(--duration-fast);
}

.auth-submit:hover {
  opacity: 0.92;
}

.auth-submit:active {
  transform: scale(0.98);
}

.auth-switch-hint {
  text-align: center;
  margin-top: var(--space-5);
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.auth-switch-hint a {
  color: var(--text-accent);
  font-weight: var(--weight-medium);
  cursor: pointer;
}

/* ── Settings detail modal extras (device/service lists, EQ) ── */
.detail-list-item.with-action {
  justify-content: space-between;
}

.detail-action-btn {
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-smooth);
  flex-shrink: 0;
}

.detail-action-btn.danger {
  background: rgba(239, 68, 68, 0.15);
  color: var(--color-error);
}

.detail-action-btn.danger:hover {
  background: rgba(239, 68, 68, 0.25);
}

.detail-action-btn.connect {
  background: rgba(16, 185, 129, 0.15);
  color: var(--color-success);
}

.detail-action-btn.connected {
  background: var(--bg-hover);
  color: var(--text-secondary);
}

.eq-slider-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.eq-slider-row label {
  width: 64px;
  font-size: var(--text-xs);
  color: var(--text-secondary);
  flex-shrink: 0;
}

.eq-slider-row input[type="range"] {
  flex: 1;
  accent-color: var(--accent-purple);
}


/* ============================================
   NEVER — Page Styles
   ============================================ */

/* ── Screens Container ───────────────────── */
.screens-container {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.screen {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  padding-bottom: calc(var(--nav-height) + var(--mini-player-height) + 24px);
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-medium) var(--ease-smooth);
  z-index: 1;
}

.screen.active {
  opacity: 1;
  pointer-events: auto;
  z-index: 2;
}

/* ══════════════════════════════════════════
   HOME PAGE
   ══════════════════════════════════════════ */

/* Hero Greeting */
.home-hero {
  padding: var(--space-5);
  padding-top: calc(var(--status-bar-height) + var(--space-8));
  position: relative;
}

.hero-greeting {
  font-size: var(--text-2xl);
  font-weight: var(--weight-extrabold);
  color: var(--text-primary);
  letter-spacing: var(--tracking-tight);
  margin-bottom: var(--space-1);
}

.hero-greeting .wave-emoji {
  display: inline-block;
  animation: float 3s ease-in-out infinite;
}

.hero-date {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  font-weight: var(--weight-medium);
}

/* Continue Listening Section */
.continue-section .h-scroll {
  padding-left: var(--space-5);
  gap: var(--space-3);
}

.continue-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
  padding: 0 var(--space-5);
}

/* Wave Section */
.wave-section {
  padding: var(--space-4) 0;
}

/* Horizontal Scroll Sections */
.h-scroll-section .h-scroll {
  padding-left: var(--space-5);
  gap: var(--space-3);
}

.h-scroll-section .h-scroll::after {
  content: '';
  min-width: var(--space-5);
}

/* Top Tracks */
.top-tracks-section {
  padding: 0 var(--space-5);
}

.top-tracks-list {
  display: flex;
  flex-direction: column;
}

/* Recently Listened Artists */
.recent-artists .h-scroll {
  padding-left: var(--space-5);
  gap: var(--space-4);
}

.recent-artists .h-scroll::after {
  content: '';
  min-width: var(--space-5);
}

/* ══════════════════════════════════════════
   FOR YOU PAGE
   ══════════════════════════════════════════ */
.foryou-header {
  padding: var(--space-5);
  padding-top: calc(var(--status-bar-height) + var(--space-8));
}

.foryou-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-extrabold);
  margin-bottom: var(--space-1);
}

.foryou-subtitle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

/* AI Badge */
.ai-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: 2px 10px;
  background: var(--accent-gradient);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: white;
  margin-left: var(--space-2);
  vertical-align: middle;
}

/* Mood Grid */
.mood-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
  padding: 0 var(--space-5);
}

/* Time of Day Section */
.time-section {
  padding: 0 var(--space-5);
}

.time-card {
  width: 100%;
  padding: var(--space-5);
  border-radius: var(--radius-xl);
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.time-card-content {
  position: relative;
  z-index: 2;
}

.time-card-label {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: var(--space-1);
}

.time-card-title {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: white;
  margin-bottom: var(--space-1);
}

.time-card-desc {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.6);
}

/* Genre Map */
.genre-bubbles {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  padding: 0 var(--space-5);
}

.genre-bubble {
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-spring);
  border: 1px solid transparent;
}

.genre-bubble:hover {
  transform: scale(1.05);
}

.genre-bubble:active {
  transform: scale(0.95);
}

/* Concert Card */
.concert-card {
  display: flex;
  gap: var(--space-4);
  padding: var(--space-4);
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  margin: 0 var(--space-5);
  cursor: pointer;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.concert-card:hover {
  background: var(--bg-elevated);
  border-color: var(--border-default);
}

.concert-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: var(--accent-gradient);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.concert-day {
  font-size: var(--text-xl);
  font-weight: var(--weight-black);
  color: white;
  line-height: 1;
}

.concert-month {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: rgba(255, 255, 255, 0.8);
  text-transform: uppercase;
}

.concert-info {
  flex: 1;
  min-width: 0;
}

.concert-name {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 2px;
}

.concert-venue {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.concert-city {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* ══════════════════════════════════════════
   LIBRARY PAGE
   ══════════════════════════════════════════ */
.library-header {
  padding: var(--space-5);
  padding-top: calc(var(--status-bar-height) + var(--space-8));
}

.library-title {
  font-size: var(--text-2xl);
  font-weight: var(--weight-extrabold);
  margin-bottom: var(--space-4);
}

.library-search {
  padding: 0 var(--space-5);
  margin-bottom: var(--space-4);
}

.library-categories {
  padding: 0;
}

/* Library Category Items */
.lib-category {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-5);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-smooth);
  border-bottom: 1px solid var(--border-subtle);
}

.lib-category:last-child {
  border-bottom: none;
}

.lib-category:hover {
  background: var(--bg-hover);
}

.lib-icon {
  width: 52px;
  height: 52px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.lib-icon svg {
  width: 24px;
  height: 24px;
  stroke: white;
  stroke-width: 2;
  fill: none;
}

.lib-label {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  margin-bottom: 2px;
}

.lib-count {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

/* Filter Tags */
.filter-tags {
  display: flex;
  gap: var(--space-2);
  padding: 0 var(--space-5);
  margin-bottom: var(--space-4);
  overflow-x: auto;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

/* Playlist Grid */
.playlist-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
  padding: 0 var(--space-5);
}

.playlist-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  cursor: pointer;
  aspect-ratio: 1;
}

.playlist-card .cover-gradient {
  width: 100%;
  height: 100%;
}

.playlist-card-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-4);
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
}

.playlist-card-title {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: white;
  margin-bottom: 2px;
}

.playlist-card-count {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.7);
}

/* Create Playlist Button */
.create-playlist-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1;
  border-radius: var(--radius-lg);
  border: 2px dashed var(--border-default);
  background: rgba(255, 255, 255, 0.02);
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-smooth);
  flex-direction: column;
  gap: var(--space-2);
}

.create-playlist-btn:hover {
  border-color: var(--accent-purple);
  background: rgba(139, 92, 246, 0.05);
}

.create-playlist-btn svg {
  width: 32px;
  height: 32px;
  stroke: var(--text-tertiary);
  stroke-width: 1.5;
  fill: none;
}

.create-playlist-btn span {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  font-weight: var(--weight-medium);
}

/* ══════════════════════════════════════════
   PROFILE PAGE
   ══════════════════════════════════════════ */
.profile-header {
  padding: var(--space-6);
  padding-top: calc(var(--status-bar-height) + var(--space-8));
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200px;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.1) 0%, transparent 100%);
  pointer-events: none;
}

.profile-avatar {
  position: relative;
  margin-bottom: var(--space-4);
}

.profile-avatar .avatar-xl {
  border-color: var(--accent-purple);
  box-shadow: var(--shadow-glow-purple);
}

.profile-avatar .edit-badge {
  position: absolute;
  bottom: 4px;
  right: 4px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--bg-deep);
}

.edit-badge svg {
  width: 14px;
  height: 14px;
  stroke: white;
  stroke-width: 2;
  fill: none;
}

.profile-name {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  margin-bottom: var(--space-1);
}

.profile-handle {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

/* Profile Stats */
.profile-stats {
  display: flex;
  gap: var(--space-8);
  margin-bottom: var(--space-5);
}

.profile-stat {
  text-align: center;
}

.profile-stat-number {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  font-family: var(--font-mono);
}

.profile-stat-label {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* Music Passport Card */
.passport-card {
  width: calc(100% - 40px);
  margin: 0 auto var(--space-6);
  padding: var(--space-5);
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.10) 100%);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: var(--radius-2xl);
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.passport-card:hover {
  border-color: rgba(139, 92, 246, 0.4);
  transform: translateY(-2px);
  box-shadow: var(--shadow-glow-purple);
}

.passport-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.passport-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.passport-title {
  font-size: var(--text-base);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}

.passport-badge {
  padding: 2px 10px;
  border-radius: var(--radius-full);
  background: var(--accent-gradient);
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: white;
}

.passport-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}

.passport-stat {
  text-align: center;
}

.passport-stat-value {
  font-size: var(--text-2xl);
  font-weight: var(--weight-black);
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-family: var(--font-mono);
}

.passport-stat-label {
  font-size: 10px;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
  margin-top: 4px;
}

/* Subscription Card */
.sub-card {
  width: calc(100% - 40px);
  margin: 0 auto var(--space-4);
  padding: var(--space-4);
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  gap: var(--space-4);
  cursor: pointer;
  transition: all var(--duration-medium) var(--ease-smooth);
}

.sub-card:hover {
  background: var(--bg-elevated);
  border-color: var(--border-default);
}

.sub-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sub-icon svg {
  width: 24px;
  height: 24px;
  stroke: white;
  stroke-width: 2;
  fill: none;
}

.sub-info {
  flex: 1;
}

.sub-plan {
  font-size: var(--text-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

.sub-expires {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 2px;
}

/* Settings Sections */
.settings-section {
  margin-bottom: var(--space-4);
}

.settings-section-title {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
  color: var(--text-tertiary);
  padding: var(--space-3) var(--space-5);
}

/* Setting Rows */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-smooth);
  border-bottom: 1px solid var(--border-subtle);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-row:hover {
  background: var(--bg-hover);
}

.setting-row-left {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex: 1;
  min-width: 0;
}

.setting-row-right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.setting-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.setting-icon svg {
  width: 20px;
  height: 20px;
  stroke: var(--text-secondary);
  stroke-width: 1.8;
  fill: none;
}

.setting-label {
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--text-primary);
}

.setting-sublabel {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: 1px;
}

.chevron-right {
  width: 16px;
  height: 16px;
  stroke: var(--text-muted);
  stroke-width: 2;
  fill: none;
}

/* Badge */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 22px;
  height: 22px;
  padding: 0 6px;
  border-radius: var(--radius-full);
  background: var(--accent-purple);
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: white;
}

/* Ghost Button (Profile) */
.btn-ghost {
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-full);
  border: 1px solid var(--border-default);
  background: transparent;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-smooth);
  font-family: var(--font-primary);
}

.btn-ghost:hover {
  border-color: var(--accent-purple);
  color: var(--accent-purple);
  background: rgba(139, 92, 246, 0.05);
}

/* ══════════════════════════════════════════
   FULL-SCREEN PLAYER
   ══════════════════════════════════════════ */
.player-fullscreen {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: var(--content-max-width);
  height: 100%;
  z-index: var(--z-player);
  display: flex;
  flex-direction: column;
  transition: transform var(--duration-slow) var(--ease-spring-soft),
              opacity var(--duration-medium) var(--ease-smooth);
  pointer-events: none;
  opacity: 0;
  transform: translateX(-50%) translateY(100%);
}

.player-fullscreen.open {
  opacity: 1;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}

/* Player Background */
.player-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}

.player-bg-image {
  position: absolute;
  inset: -50px;
  filter: blur(60px) saturate(150%) brightness(0.3);
  transform: scale(1.3);
  opacity: 0.6;
}

.player-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg,
    rgba(7, 7, 13, 0.3) 0%,
    rgba(7, 7, 13, 0.6) 40%,
    rgba(7, 7, 13, 0.95) 100%
  );
}

/* Player Header */
.player-header {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  padding-top: calc(var(--status-bar-height) + var(--space-4));
}

.player-handle {
  width: 36px;
  height: 4px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-full);
  position: absolute;
  top: calc(var(--status-bar-height) + 8px);
  left: 50%;
  transform: translateX(-50%);
}

.player-header-text {
  text-align: center;
  flex: 1;
}

.player-header-label {
  font-size: var(--text-xs);
  font-weight: var(--weight-medium);
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: var(--tracking-wider);
}

.player-header-source {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
}

/* Player Cover Art */
.player-cover-container {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4) var(--space-8);
  min-height: 0;
}

.player-cover {
  width: 100%;
  max-width: 340px;
  aspect-ratio: 1;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 80px rgba(139, 92, 246, 0.1);
  position: relative;
  transition: transform var(--duration-slow) var(--ease-spring-soft);
}

.player-cover img,
.player-cover .cover-gradient {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Vinyl Mode */
.player-cover.vinyl-mode {
  border-radius: 50%;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5),
              0 0 0 8px rgba(255, 255, 255, 0.05),
              inset 0 0 40px rgba(0, 0, 0, 0.3);
}

.player-cover.vinyl-mode::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24%;
  height: 24%;
  border-radius: 50%;
  background: var(--bg-deepest);
  border: 3px solid rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);
}

/* Visualizer */
.player-visualizer {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 3px;
  height: 40px;
  padding: 0 var(--space-8);
  position: relative;
  z-index: 2;
  margin-bottom: var(--space-3);
}

.player-viz-bar {
  width: 4px;
  border-radius: 2px;
  background: var(--accent-gradient);
  opacity: 0.6;
  transform-origin: bottom;
  transition: height 0.1s ease;
}

/* Player Track Info */
.player-track-info {
  position: relative;
  z-index: 2;
  padding: 0 var(--space-6);
  margin-bottom: var(--space-4);
}

.player-track-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-4);
}

.player-track-text {
  flex: 1;
  min-width: 0;
}

.player-track-title {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-primary);
  letter-spacing: var(--tracking-tight);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}

.player-track-artist {
  font-size: var(--text-base);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
}

/* Progress Bar (Player) */
.player-progress {
  position: relative;
  z-index: 2;
  padding: 0 var(--space-6);
  margin-bottom: var(--space-3);
}

.player-progress-bar {
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.10);
  border-radius: var(--radius-full);
  cursor: pointer;
  position: relative;
  transition: height var(--duration-fast) var(--ease-smooth);
}

.player-progress-bar:hover {
  height: 6px;
}

.player-progress-fill {
  height: 100%;
  background: var(--accent-gradient-horizontal);
  border-radius: var(--radius-full);
  position: relative;
  transition: width 0.1s linear;
}

.player-progress-fill::after {
  content: '';
  position: absolute;
  right: -6px;
  top: 50%;
  transform: translateY(-50%) scale(0);
  width: 14px;
  height: 14px;
  background: white;
  border-radius: 50%;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.player-progress-bar:hover .player-progress-fill::after {
  transform: translateY(-50%) scale(1);
}

.player-time {
  display: flex;
  justify-content: space-between;
  margin-top: var(--space-2);
}

.player-time span {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  font-family: var(--font-mono);
}

/* Player Controls */
.player-controls {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-6);
  padding: 0 var(--space-6);
  margin-bottom: var(--space-5);
}

.player-btn {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.player-btn:active {
  transform: scale(0.88);
}

.player-btn svg {
  width: 24px;
  height: 24px;
  fill: var(--text-secondary);
}

.player-btn.active svg {
  fill: var(--accent-purple);
}

.player-btn-main {
  width: 64px;
  height: 64px;
  background: var(--accent-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-glow-accent);
  transition: all var(--duration-normal) var(--ease-spring);
}

.player-btn-main:hover {
  transform: scale(1.05);
  box-shadow: 0 8px 40px rgba(139, 92, 246, 0.4);
}

.player-btn-main:active {
  transform: scale(0.93);
}

.player-btn-main svg {
  width: 28px;
  height: 28px;
  fill: white;
}

/* Player Secondary Controls */
.player-secondary {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 var(--space-8);
  padding-bottom: calc(var(--bottom-safe) + var(--space-6));
}

.player-sec-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all var(--duration-fast) var(--ease-smooth);
}

.player-sec-btn:active {
  transform: scale(0.88);
}

.player-sec-btn svg {
  width: 20px;
  height: 20px;
  stroke: var(--text-tertiary);
  stroke-width: 1.8;
  fill: none;
}

.player-sec-btn.active svg {
  stroke: var(--accent-purple);
}

/* ── Lyrics Overlay ──────────────────────── */
.lyrics-overlay {
  position: fixed;
  inset: 0;
  z-index: calc(var(--z-player) + 1);
  background: var(--glass-bg-heavy);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  display: flex;
  flex-direction: column;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-medium) var(--ease-smooth);
}

.lyrics-overlay.open {
  opacity: 1;
  pointer-events: auto;
}

.lyrics-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  padding-top: calc(var(--status-bar-height) + var(--space-4));
}

.lyrics-content {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.lyrics-line {
  font-size: var(--text-xl);
  font-weight: var(--weight-bold);
  color: var(--text-muted);
  line-height: var(--leading-relaxed);
  transition: all var(--duration-medium) var(--ease-smooth);
  cursor: pointer;
}

.lyrics-line.active {
  color: var(--text-primary);
  font-size: var(--text-2xl);
  text-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
}

.lyrics-line:hover {
  color: var(--text-secondary);
}

/* ══════════════════════════════════════════
   DESKTOP LAYOUT
   ══════════════════════════════════════════ */
@media (min-width: 1024px) {
  .screens-container {
    grid-column: 2;
    grid-row: 1;
    padding-bottom: var(--mini-player-height);
  }

  .bottom-nav {
    position: static;
    transform: none;
    max-width: none;
    width: var(--sidebar-width);
    height: 100%;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    padding: var(--space-6) var(--space-4);
    gap: 0;
    grid-column: 1;
    grid-row: 1 / -1;
    border-top: none;
    border-right: 1px solid var(--border-subtle);
    background: var(--bg-secondary);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3) var(--space-6);
  }

  .nav-logo-icon {
    width: 26px;
    height: 26px;
    object-fit: contain;
  }

  .nav-logo-text {
    font-size: var(--text-lg);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
  }

  .nav-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .nav-item {
    width: 100%;
    height: auto;
    flex-direction: row;
    justify-content: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-md);
  }

  .nav-item.active {
    transform: none;
    background: var(--bg-hover);
  }

  .nav-item.active::after {
    display: none;
  }

  .nav-item-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-tertiary);
  }

  .nav-item.active .nav-item-label {
    color: var(--text-primary);
    font-weight: var(--weight-semibold);
  }

  .mini-player {
    position: fixed;
    left: var(--sidebar-width);
    right: 0;
    bottom: 0;
    top: auto;
    transform: none;
    width: auto;
    max-width: none;
    border-radius: 0;
    margin: 0;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
  }

  .screen {
    padding-bottom: var(--space-16);
  }

  .continue-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .mood-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .playlist-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .player-fullscreen {
    max-width: 100%;
    width: 100%;
  }
}

/* ══════════════════════════════════════════
   ULTRA-WIDE POLISH
   Sidebar stays flush at the real corner (fixed above),
   but content stops stretching edge-to-edge on very
   wide monitors so cards/text stay readable.
   ══════════════════════════════════════════ */
@media (min-width: 1600px) {
  .screens-container {
    max-width: 1400px;
    margin: 0 auto;
  }
}

  </style>
</head>
<body>

  <!-- Real audio engine — plays actual streamed audio from Audius
       (see js/audius.js). Controlled via the standard HTMLMediaElement
       API in player.js — no mock/simulated playback. -->
  <audio id="audio-engine" preload="auto"></audio>

  <!-- ═══════════ Auth Screen ═══════════ -->
  <div class="auth-screen" id="auth-screen">
    <div class="ambient-bg">
      <div class="ambient-orb ambient-orb-1"></div>
      <div class="ambient-orb ambient-orb-2"></div>
      <div class="ambient-orb ambient-orb-3"></div>
    </div>

    <div class="auth-card">
      <div class="auth-logo" style="display:flex;align-items:center;justify-content:center;gap:var(--space-2)">
        <img src="data:image/png;base64," alt="Never" style="width:34px;height:34px;object-fit:contain">
        <span>Never</span>
      </div>
      <p class="auth-tagline" id="auth-tagline">Заходи и слушай своё</p>

      <div class="auth-tabs">
        <button class="auth-tab active" id="auth-tab-login" onclick="auth.switchTab('login')">Вход</button>
        <button class="auth-tab" id="auth-tab-register" onclick="auth.switchTab('register')">Регистрация</button>
      </div>

      <!-- Social providers -->
      <div class="auth-social">
        <button class="auth-social-btn auth-social-google" onclick="auth.loginWithProvider('google')">
          <span class="auth-social-icon auth-social-icon-google">
            <svg viewBox="0 0 48 48">
              <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12s5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
              <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
              <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
              <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
            </svg>
          </span>
          Продолжить с Google
        </button>
        <button class="auth-social-btn auth-social-apple" onclick="auth.loginWithProvider('apple')">
          <span class="auth-social-icon auth-social-icon-apple">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.462 2.13-1.164 2.9-.78.85-2.06 1.51-3.09 1.43-.13-1.12.44-2.28 1.16-3.03.79-.83 2.14-1.45 3.09-1.3zM20.5 17.28c-.53 1.22-1.17 2.44-2.09 3.55-.84 1.02-1.87 2.27-3.19 2.28-1.17.02-1.5-.75-3.03-.75-1.53 0-1.9.73-3.02.77-1.28.05-2.25-1.1-3.1-2.11-1.72-2.06-3.05-5.83-1.27-8.4.88-1.28 2.38-2.09 3.86-2.11 1.24-.02 2.36.83 3.1.83.73 0 2.14-1.03 3.6-.88.61.03 2.34.25 3.44 1.86-.09.06-2.06 1.2-2.03 3.59.02 2.85 2.5 3.8 2.53 3.81-.02.06-.4 1.36-1.29 2.66z"/></svg>
          </span>
          Продолжить с Apple
        </button>
        <button class="auth-social-btn auth-social-discord" onclick="auth.loginWithProvider('discord')">
          <span class="auth-social-icon auth-social-icon-discord">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.3 5.4A17.6 17.6 0 0015.7 4l-.3.5c1.7.4 2.7 1 3.7 1.7-1.6-.8-3.2-1.2-4.9-1.2h-.4c-1.7 0-3.3.4-4.9 1.2 1-.7 2.2-1.4 3.7-1.7L12.3 4a17.5 17.5 0 00-4.6 1.4C5.4 8.9 4.7 12.3 5 15.6a17.9 17.9 0 005.2 2.6l.7-1c-.9-.3-1.7-.7-2.5-1.3l.4-.3c2.9 1.3 6 1.3 8.9 0l.4.3c-.8.6-1.6 1-2.5 1.3l.7 1a17.8 17.8 0 005.2-2.6c.4-3.9-.6-7.3-2.2-10.2zM9.7 13.6c-.7 0-1.3-.7-1.3-1.5s.6-1.5 1.3-1.5 1.3.7 1.3 1.5-.6 1.5-1.3 1.5zm5.3 0c-.7 0-1.3-.7-1.3-1.5s.6-1.5 1.3-1.5 1.3.7 1.3 1.5-.6 1.5-1.3 1.5z"/></svg>
          </span>
          Продолжить с Discord
        </button>
        <button class="auth-social-btn auth-social-telegram" onclick="auth.loginWithProvider('telegram')">
          <span class="auth-social-icon auth-social-icon-telegram">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.5 4.5l-3.1 15c-.2 1-.9 1.3-1.7.8l-4.7-3.5-2.3 2.2c-.3.3-.5.5-1 .5l.3-4.9 8.9-8c.4-.3-.1-.5-.6-.2l-11 6.9-4.8-1.5c-1-.3-1-1 .2-1.5L20.2 3.4c.8-.3 1.6.2 1.3 1.1z"/></svg>
          </span>
          Продолжить с Telegram
        </button>
      </div>

      <div class="auth-divider"><span>или</span></div>

      <!-- Email / password form -->
      <form class="auth-form" id="auth-form" onsubmit="return auth.handleSubmit(event)">
        <div class="auth-field" id="auth-field-name" style="display:none">
          <label>Имя</label>
          <input type="text" id="auth-name" placeholder="Как вас зовут?" autocomplete="name">
        </div>
        <div class="auth-field">
          <label>Email</label>
          <input type="email" id="auth-email" placeholder="you@example.com" autocomplete="email" required>
        </div>
        <div class="auth-field">
          <label>Пароль</label>
          <input type="password" id="auth-password" placeholder="Минимум 6 символов" autocomplete="current-password" required minlength="6">
        </div>
        <div class="auth-field" id="auth-field-confirm" style="display:none">
          <label>Повторите пароль</label>
          <input type="password" id="auth-password-confirm" placeholder="Ещё раз">
        </div>

        <p class="auth-error" id="auth-error"></p>

        <button type="submit" class="auth-submit" id="auth-submit">Войти</button>
      </form>

      <p class="auth-switch-hint" id="auth-switch-hint">
        Нет аккаунта? <a onclick="auth.switchTab('register')">Зарегистрироваться</a>
      </p>
    </div>
  </div>

  <div id="app">

    <!-- ═══════════ Ambient Background ═══════════ -->
    <div class="ambient-bg">
      <div class="ambient-orb ambient-orb-1"></div>
      <div class="ambient-orb ambient-orb-2"></div>
      <div class="ambient-orb ambient-orb-3"></div>
    </div>

    <!-- ═══════════ Screens Container ═══════════ -->
    <div class="screens-container">

      <!-- ══════════════════════════════════════════
           HOME SCREEN
           ══════════════════════════════════════════ -->
      <div class="screen active" id="screen-home">

        <!-- Hero Greeting -->
        <div class="home-hero">
          <h1 class="hero-greeting" id="home-greeting">Добрый вечер, Алексей <span class="wave-emoji">👋</span></h1>
          <p class="hero-date" id="home-date">Среда, 2 июля</p>
        </div>

        <!-- Continue Listening -->
        <section class="continue-section">
          <div class="section-header">
            <h2 class="section-title">Продолжить</h2>
            <span class="section-action">Все</span>
          </div>
          <div class="continue-grid" id="continue-grid">
            <!-- Populated by JS -->
          </div>
        </section>

        <!-- Твоя Волна -->
        <section class="wave-section">
          <div class="section-header">
            <h2 class="section-title">Твоя Волна</h2>
          </div>
          <div class="wave-card" onclick="player.playTrack(0)">
            <div class="wave-card-content">
              <div class="wave-card-label">Персональный микс</div>
              <div class="wave-card-title">Твоя Волна</div>
              <div class="wave-card-subtitle">AI подобрал музыку под твоё настроение</div>
            </div>
            <!-- Animated wave visual -->
            <div class="wave-card-visual">
              <svg viewBox="0 0 200 160" preserveAspectRatio="none" style="width:100%;height:100%;opacity:0.15">
                <defs>
                  <linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" style="stop-color:#8B5CF6"/>
                    <stop offset="100%" style="stop-color:#3B82F6"/>
                  </linearGradient>
                </defs>
                <path d="M0,80 Q25,40 50,80 T100,80 T150,80 T200,80 L200,160 L0,160 Z" fill="url(#waveGrad)" class="wave-animate"/>
                <path d="M0,100 Q30,60 60,100 T120,100 T180,100 T240,100 L200,160 L0,160 Z" fill="url(#waveGrad)" opacity="0.5" class="wave-animate" style="animation-delay:-3s"/>
              </svg>
            </div>
